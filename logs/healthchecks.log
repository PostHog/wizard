t/dashboard.html\", {})\n444\t\n445\t\n446\tdef _replace_placeholders(doc: str, html: str) -> str:\n447\t    if doc.startswith(\"self_hosted\"):\n448\t        return html\n449\t\n450\t    limit = settings.PING_BODY_LIMIT or 100\n451\t    if limit % 1000 == 0:\n452\t        limit_fmt = f\"{limit // 1000} kB\"\n453\t    else:\n454\t        limit_fmt = f\"{limit} bytes\"\n455\t\n456\t    replaces = {\n457\t        \"{{ default_timeout }}\": str(int(DEFAULT_TIMEOUT.total_seconds())),\n458\t        \"{{ default_grace }}\": str(int(DEFAULT_GRACE.total_seconds())),\n459\t        \"SITE_NAME\": settings.SITE_NAME,\n460\t        \"SITE_ROOT\": settings.SITE_ROOT,\n461\t        \"SITE_HOSTNAME\": site_hostname(),\n462\t        \"SITE_SCHEME\": urlparse(settings.SITE_ROOT).scheme,\n463\t        \"PING_ENDPOINT\": settings.PING_ENDPOINT,\n464\t        \"PING_URL\": settings.PING_ENDPOINT + \"your-uuid-here\",\n465\t        \"PING_BODY_LIMIT_FORMATTED\": limit_fmt,\n466\t        \"PING_BODY_LIMIT\": str(limit),\n467\t        \"IMG_URL\": os.path.join(settings.STATIC_URL, \"img/docs\"),\n468\t    }\n469\t\n470\t    for placeholder, value in replaces.items():\n471\t        html = html.replace(placeholder, value)\n472\t\n473\t    return html\n474\t\n475\t\n476\tdef serve_doc(request: HttpRequest, doc: str = \"introduction\") -> HttpResponse:\n477\t    # Filenames in /templates/docs/ consist of lowercase letters and underscores,\n478\t    # -- make sure we don't accept anything else\n479\t    if not re.match(r\"^[0-9a-z_]+$\", doc):\n480\t        raise Http404(\"not found\")\n481\t\n482\t    path = settings.BASE_DIR / f\"templates/docs/{doc}.html-fragment\"\n483\t    if not path.exists():\n484\t        raise Http404(\"not found\")\n485\t\n486\t    with path.open(\"r\", encoding=\"utf-8\") as f:\n487\t        content = f.read()\n488\t\n489\t    content = _replace_placeholders(doc, content)\n490\t    ctx = {\n491\t        \"page\": \"docs\",\n492\t        \"section\": doc,\n493\t        \"content\": content,\n494\t        \"first_line\": content.split(\"\\n\")[0],\n495\t    }\n496\t\n497\t    return render(request, \"front/docs_single.html\", ctx)\n498\t\n499\t\n500\t@csrf_exempt\n501\tdef docs_search(request: HttpRequest) -> HttpResponse:\n502\t    form = forms.SearchForm(request.GET)\n503\t    if not form.is_valid():\n504\t        return render(request, \"front/docs_search.html\", {\"results\": []})\n505\t\n506\t    query = \"\"\"\n507\t        SELECT slug, title, snippet(docs, 2, '<span>', '</span>', '&hellip;', 10)\n508\t        FROM docs\n509\t        WHERE docs MATCH ?\n510\t        ORDER BY bm25(docs, 2.0, 10.0, 1.0)\n511\t        LIMIT 8\n512\t    \"\"\"\n513\t\n514\t    # Wrap the query in double quotes to get a valid FTS string\n515\t    # https://www.sqlite.org/fts5.html#full_text_query_syntax\n516\t    q = '\"%s\"' % form.cleaned_data[\"q\"]\n517\t    con = sqlite3.connect(settings.BASE_DIR / \"search.db\")\n518\t    cur = con.cursor()\n519\t    res = cur.execute(query, (q,))\n520\t\n521\t    ctx = {\"results\": res.fetchall()}\n522\t    return render(request, \"front/docs_search.html\", ctx)\n523\t\n524\t\n525\tdef docs_cron(request: HttpRequest) -> HttpResponse:\n526\t    return render(request, \"front/docs_cron.html\", {\"page\": \"docs-cron\"})\n527\t\n528\t\n529\t@require_POST\n530\t@login_required\n531\tdef add_check(request: AuthenticatedHttpRequest, code: UUID) -> HttpResponse:\n532\t    project = _get_rw_project_for_user(request, code)\n533\t    if project.num_checks_available() <= 0:\n534\t        return HttpResponseBadRequest()\n535\t\n536\t    form = forms.AddCheckForm(request.POST)\n537\t    if not form.is_valid():\n538\t        return HttpResponseBadRequest()\n539\t\n540\t    check = Check(project=project)\n541\t    check.name = form.cleaned_data[\"name\"]\n542\t    check.slug = form.cleaned_data[\"slug\"]\n543\t    check.tags = form.cleaned_data[\"tags\"]\n544\t    check.kind = form.cleaned_data[\"kind\"]\n545\t    check.timeout = form.cleaned_data[\"timeout\"]\n546\t    check.schedule = form.cleaned_data[\"schedule\"]\n547\t    check.tz = form.cleaned_data[\"tz\"]\n548\t    check.grace = form.cleaned_data[\"grace\"]\n549\t    check.save()\n550\t\n551\t    check.assign_all_channels()\n552\t\n553\t    url = reverse(\"hc-checks\", args=[project.code])\n554\t    url += _get_referer_qs(request)  # Preserve selected tags and search\n555\t    return redirect(url)\n556\t\n557\t\n558\t@require_POST\n559\t@login_required\n560\tdef update_name(request: AuthenticatedHttpRequest, code: UUID) -> HttpResponse:\n561\t    check = _get_rw_check_for_user(request, code)\n562\t\n563\t    form = forms.NameTagsForm(request.POST)\n564\t    if form.is_valid():\n565\t        check.name = form.cleaned_data[\"name\"]\n566\t        check.slug = form.cleaned_data[\"slug\"]\n567\t        check.tags = form.cleaned_data[\"tags\"]\n568\t        check.desc = form.cleaned_data[\"desc\"]\n569\t        check.save()\n570\t\n571\t    if \"/details/\" in request.headers.get(\"Referer\", \"\"):\n572\t        return redirect(\"hc-details\", code)\n573\t\n574\t    url = reverse(\"hc-checks\", args=[check.project.code])\n575\t    url += _get_referer_qs(request)  # Preserve selected tags and search\n576\t    return redirect(url)\n577\t\n578\t\n579\t@require_POST\n580\t@login_required\n581\tdef filtering_rules(request: AuthenticatedHttpRequest, code: UUID) -> HttpResponse:\n582\t    check = _get_rw_check_for_user(request, code)\n583\t\n584\t    form = forms.FilteringRulesForm(request.POST)\n585\t    if form.is_valid():\n586\t        check.filter_subject = form.cleaned_data[\"filter_subject\"]\n587\t        check.filter_body = form.cleaned_data[\"filter_body\"]\n588\t        check.filter_http_body = form.cleaned_data[\"filter_http_body\"]\n589\t        check.filter_default_fail = form.cleaned_data[\"filter_default_fail\"]\n590\t        check.start_kw = form.cleaned_data[\"start_kw\"]\n591\t        check.success_kw = form.cleaned_data[\"success_kw\"]\n592\t        check.failure_kw = form.cleaned_data[\"failure_kw\"]\n593\t\n594\t        check.methods = form.cleaned_data[\"methods\"]\n595\t        check.manual_resume = form.cleaned_data[\"manual_resume\"]\n596\t        check.save()\n597\t\n598\t    return redirect(\"hc-details\", code)\n599\t"
