        "content": "599\t\n600\t\n601\t@require_POST\n602\t@login_required\n603\tdef update_timeout(request: AuthenticatedHttpRequest, code: UUID) -> HttpResponse:\n604\t    check = _get_rw_check_for_user(request, code)\n605\t\n606\t    kind = request.POST.get(\"kind\")\n607\t    if kind == \"simple\":\n608\t        simple_form = forms.TimeoutForm(request.POST)\n609\t        if not simple_form.is_valid():\n610\t            return HttpResponseBadRequest()\n611\t\n612\t        check.kind = \"simple\"\n613\t        check.timeout = simple_form.cleaned_data[\"timeout\"]\n614\t        check.grace = simple_form.cleaned_data[\"grace\"]\n615\t    elif kind == \"cron\":\n616\t        cron_form = forms.CronForm(request.POST)\n617\t        if not cron_form.is_valid():\n618\t            return HttpResponseBadRequest()\n619\t\n620\t        check.kind = \"cron\"\n621\t        check.schedule = cron_form.cleaned_data[\"schedule\"]\n622\t        check.tz = cron_form.cleaned_data[\"tz\"]\n623\t        check.grace = cron_form.cleaned_data[\"grace\"]\n624\t    elif kind == \"oncalendar\":\n625\t        oncalendar_form = forms.OnCalendarForm(request.POST)\n626\t        if not oncalendar_form.is_valid():\n627\t            return HttpResponseBadRequest()\n628\t\n629\t        check.kind = \"oncalendar\"\n630\t        check.schedule = oncalendar_form.cleaned_data[\"schedule\"]\n631\t        check.tz = oncalendar_form.cleaned_data[\"tz\"]\n632\t        check.grace = oncalendar_form.cleaned_data[\"grace\"]\n633\t\n634\t    check.alert_after = check.going_down_after()\n635\t    check_saved = False\n636\t    if check.status == \"up\":\n637\t        assert check.alert_after\n638\t        if check.alert_after < now():\n639\t            # Checks can flip from \"up\" to \"down\" state as a result of changing check's\n640\t            # schedule.  We don't want to send notifications when changing schedule\n641\t            # interactively in the web UI. So we update the `alert_after` and `status`\n642\t            # fields, and create a Flip object here the same way as `sendalerts` would\n643\t            # do, but without sending an actual alert.\n644\t            #\n645\t            # We need to create the Flip object because otherwise the calculation\n646\t            # in Check.downtimes() will come out wrong (when this check later comes up,\n647\t            # we will have no record of when it went down).\n648\t            check.create_flip(\"down\", mark_as_processed=True)\n649\t\n650\t            check.alert_after = None\n651\t            check.status = \"down\"\n652\t\n653\t            # Kick off nags. This would normally happen in the sendalerts management\n654\t            # command while processing a flip, but we have already marked the flip\n655\t            # as processed\n656\t            check.save()\n657\t            check_saved = True\n658\t            check.project.update_next_nag_dates()\n659\t\n660\t    if not check_saved:\n661\t        check.save()\n662\t\n663\t    if \"/details/\" in request.headers.get(\"Referer\", \"\"):\n664\t        return redirect(\"hc-details\", code)\n665\t\n666\t    url = reverse(\"hc-checks\", args=[check.project.code])\n667\t    url += _get_referer_qs(request)  # Preserve selected tags and search\n668\t    return redirect(url)\n669\t\n670\t\n671\t@require_POST\n672\tdef cron_preview(request: HttpRequest) -> HttpResponse:\n673\t    form = forms.CronPreviewForm(request.POST)\n674\t    if not form.is_valid():\n675\t        return render(request, \"front/cron_preview.html\", {\"form\": form})\n676\t\n677\t    tz = form.cleaned_data[\"tz\"]\n678\t    now_local = now().astimezone(ZoneInfo(tz))\n679\t    it = CronSim(form.cleaned_data[\"schedule\"], now_local)\n680\t    ctx = {\n681\t        \"tz\": tz,\n682\t        \"dates\": list(islice(it, 0, 6)),\n683\t        \"desc\": it.explain(),\n684\t    }\n685\t    return render(request, \"front/cron_preview.html\", ctx)\n686\t\n687\t\n688\t@require_POST\n689\t@login_required\n690\tdef oncalendar_preview(request: HttpRequest) -> HttpResponse:\n691\t    schedule = request.POST.get(\"schedule\", \"\")\n692\t    tz = request.POST.get(\"tz\")\n693\t    ctx: dict[str, object] = {\"tz\": tz, \"dates\": []}\n694\t\n695\t    if tz not in all_timezones:\n696\t        ctx[\"bad_tz\"] = True\n697\t        return render(request, \"front/oncalendar_preview.html\", ctx)\n698\t\n699\t    now_local = now().astimezone(ZoneInfo(tz))\n700\t    try:\n701\t        it = OnCalendar(schedule, now_local)\n702\t        iterations = 6 if tz == \"UTC\" else 4\n703\t        ctx[\"dates\"] = list(islice(it, 0, iterations))\n704\t    except OnCalendarError:\n705\t        ctx[\"bad_schedule\"] = True\n706\t\n707\t    if not ctx[\"dates\"]:\n708\t        ctx[\"bad_schedule\"] = True\n709\t\n710\t    return render(request, \"front/oncalendar_preview.html\", ctx)\n711\t\n712\t\n713\tdef validate_schedule(request: HttpRequest) -> HttpResponse:\n714\t    kind = request.GET.get(\"kind\", \"\")\n715\t\n716\t    validator: CronValidator | OnCalendarValidator\n717\t    if kind == \"cron\":\n718\t        validator = CronValidator()\n719\t    elif kind == \"oncalendar\":\n720\t        validator = OnCalendarValidator()\n721\t    else:\n722\t        return HttpResponseBadRequest()\n723\t\n724\t    schedule = request.GET.get(\"schedule\", \"\")\n725\t    try:\n726\t        validator(schedule)\n727\t        return JsonResponse({\"result\": True})\n728\t    except ValidationError:\n729\t        return JsonResponse({\"result\": False})\n730\t\n731\t\n732\t@login_required\n733\tdef ping_details(\n734\t    request: AuthenticatedHttpRequest, code: UUID, n: int | None = None\n735\t) -> HttpResponse:\n736\t    # This view makes two non-obvious SQL queries:\n737\t    # * it calls ping.get_body(), which reads self.owner.code, triggering a query\n738\t    # * the template calls ping.duration() which queries past \"/start\" events\n739\t\n740\t    check, rw = _get_check_for_user(request, code)\n741\t    q = Ping.objects.filter(owner=check)\n742\t    if n:\n743\t        q = q.filter(n=n)\n744\t    else:\n745\t        # When n is not specified, look up the most recent success or failure,\n746\t        # ignoring \"start\", \"log\", \"ign\" events\n747\t        q = q.exclude(kind__in=(\"start\", \"log\", \"ign\"))\n748\t\n749\t    try:\n750\t        ping = q.latest(\"created\")\n751\t    except Ping.DoesNotExist:\n752\t        return render(request, \"front/ping_details_not_found.html\")\n753\t\n754\t    try:\n755\t        body_bytes = ping.get_body_bytes()\n756\t    except Ping.GetBodyError:\n757\t        body_bytes = None\n758\t\n759\t    ctx = {\n760\t        \"check\": check,\n761\t        \"ping\": ping,\n762\t        \"body\": body_bytes.decode(errors=\"replace\") if body_bytes else None,\n763\t        \"plain\": None,\n764\t        \"html\": None,\n765\t        \"active\": None,\n766\t        \"tz_switches\": _tz_switches(request.profile, check),\n767\t    }\n768\t\n769\t    if ping.scheme == \"email\" and body_bytes:\n770\t        # Don't use message_from_string here, it seems to mangle\n771\t        # UTF8 in message body.\n772\t        parsed = email.message_from_bytes(body_bytes, policy=email.policy.SMTP)\n773\t        ctx[\"subject\"] = parsed.get(\"subject\", \"\")\n774\t\n775\t        # The \"active\" tab is set to show the value that's successfully parsed last.\n776\t        # Per the current implementation, this means that if both plain text and HTML\n777\t        # content are present, the ping details dialog will initially display the HTML\n778\t        # content, otherwise - only one content type exists, and we default to that\n779\t        # (either plain text or HTML, at least one of them should exist in a\n780\t        # valid email).\n781\t        #\n782\t        # NOTE: If both plain text and html have not been parsed successfully the\n783\t        # \"active\" tab is not set at all, but currently this is not an issue since in\n784\t        # this case the \"ping details\" template does not render any tabs.\n785\t\n786\t        plain_mime_part = parsed.get_body((\"plain\",))\n787\t        if plain_mime_part:\n788\t            ctx[\"plain\"] = plain_mime_part.get_content()\n789\t            ctx[\"active\"] = \"plain\"\n790\t\n791\t        html_mime_part = parsed.get_body((\"html\",))\n792\t        if html_mime_part:\n793\t            ctx[\"html\"] = html_mime_part.get_content()\n794\t            ctx[\"active\"] = \"html\"\n795\t\n796\t    return render(request, \"front/ping_details.html\", ctx)\n797\t\n798\t"
