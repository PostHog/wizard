        "content": "797\t\n798\t\n799\t@login_required\n800\tdef ping_body(request: AuthenticatedHttpRequest, code: UUID, n: int) -> HttpResponse:\n801\t    check, rw = _get_check_for_user(request, code)\n802\t    ping = get_object_or_404(Ping, owner=check, n=n)\n803\t\n804\t    try:\n805\t        body = ping.get_body_bytes()\n806\t    except Ping.GetBodyError:\n807\t        return HttpResponse(status=503)\n808\t\n809\t    if not body:\n810\t        raise Http404(\"not found\")\n811\t\n812\t    response = HttpResponse(body, content_type=\"application/octet-stream\")\n813\t    filename = f\"{check.code}-{ping.n}\"\n814\t    response[\"Content-Disposition\"] = f'attachment; filename=\"{filename}.txt\"'\n815\t    return response\n816\t\n817\t\n818\t@require_POST\n819\t@login_required\n820\tdef pause(request: AuthenticatedHttpRequest, code: UUID) -> HttpResponse:\n821\t    check = _get_rw_check_for_user(request, code)\n822\t\n823\t    # Return early, without creating a flip object, if the check is already paused\n824\t    if check.status == \"paused\":\n825\t        return redirect(\"hc-details\", code)\n826\t\n827\t    # Track the status change for correct downtime calculation in Check.downtimes()\n828\t    check.create_flip(\"paused\", mark_as_processed=True)\n829\t\n830\t    check.status = \"paused\"\n831\t    check.last_start = None\n832\t    check.alert_after = None\n833\t    check.save()\n834\t\n835\t    # After pausing a check we must check if all checks are up,\n836\t    # and Profile.next_nag_date needs to be cleared out:\n837\t    check.project.update_next_nag_dates()\n838\t\n839\t    # Don't redirect after an AJAX request:\n840\t    if request.headers.get(\"X-Requested-With\") == \"XMLHttpRequest\":\n841\t        return HttpResponse()\n842\t\n843\t    return redirect(\"hc-details\", code)\n844\t\n845\t\n846\t@require_POST\n847\t@login_required\n848\tdef resume(request: AuthenticatedHttpRequest, code: UUID) -> HttpResponse:\n849\t    check = _get_rw_check_for_user(request, code)\n850\t    if check.status != \"paused\":\n851\t        return HttpResponseBadRequest()\n852\t\n853\t    check.create_flip(\"new\", mark_as_processed=True)\n854\t\n855\t    check.status = \"new\"\n856\t    check.last_start = None\n857\t    check.last_ping = None\n858\t    check.alert_after = None\n859\t    check.save()\n860\t\n861\t    return redirect(\"hc-details\", code)\n862\t\n863\t\n864\t@require_POST\n865\t@login_required\n866\tdef remove_check(request: AuthenticatedHttpRequest, code: UUID) -> HttpResponse:\n867\t    check = _get_rw_check_for_user(request, code)\n868\t\n869\t    project = check.project\n870\t    check.rename_and_delete()\n871\t    return redirect(\"hc-checks\", project.code)\n872\t\n873\t\n874\t@require_POST\n875\t@login_required\n876\tdef clear_events(request: AuthenticatedHttpRequest, code: UUID) -> HttpResponse:\n877\t    check = _get_rw_check_for_user(request, code)\n878\t\n879\t    check.status = \"new\"\n880\t    check.last_ping = None\n881\t    check.last_start = None\n882\t    check.last_duration = None\n883\t    check.has_confirmation_link = False\n884\t    check.alert_after = None\n885\t    check.save()\n886\t\n887\t    check.ping_set.all().delete()\n888\t    check.notification_set.all().delete()\n889\t    check.flip_set.all().delete()\n890\t\n891\t    return redirect(\"hc-details\", code)\n892\t\n893\t\n894\tclass PingAnnotations(TypedDict):\n895\t    body_raw_preview: bytes | memoryview[int]\n896\t\n897\t\n898\tdef _get_events(\n899\t    check: Check,\n900\t    page_limit: int,\n901\t    start: datetime,\n902\t    end: datetime,\n903\t    kinds: tuple[str, ...] | None = None,\n904\t) -> list[Notification | WithAnnotations[Ping, PingAnnotations] | Flip]:\n905\t    # Sorting by \"n\" instead of \"id\" is important here. Both give the same\n906\t    # query results, but sorting by \"id\" can cause postgres to pick\n907\t    # api_ping.id index (slow if the api_ping table is big). Sorting by\n908\t    # \"n\" works around the problem--postgres picks the api_ping.owner_id index.\n909\t    pq = check.visible_pings.order_by(\"-n\")\n910\t    pq = pq.filter(created__gte=start, created__lte=end)\n911\t    if kinds is not None:\n912\t        kinds_filter = Q(kind__in=kinds)\n913\t        if \"success\" in kinds:\n914\t            kinds_filter = kinds_filter | Q(kind__isnull=True) | Q(kind=\"\")\n915\t        pq = pq.filter(kinds_filter)\n916\t\n917\t    # Optimization: defer loading body_raw, instead load its first 150 bytes\n918\t    # as \"body_raw_preview\". This reduces both network I/O to database, and disk I/O\n919\t    # on the database host if the database contains large request bodies.\n920\t    pq = pq.defer(\"body_raw\")\n921\t    pq = pq.annotate(\n922\t        body_raw_preview=Substr(\"body_raw\", 1, 151, output_field=BinaryField())\n923\t    )\n924\t    pings = list(pq[:page_limit])\n925\t    prepare_durations(pings)\n926\t\n927\t    alerts: list[Notification] = []\n928\t    if kinds and \"notification\" in kinds:\n929\t        aq = check.notification_set.order_by(\"-created\")\n930\t        aq = aq.filter(created__gte=start, created__lte=end, check_status=\"down\")\n931\t        aq = aq.select_related(\"channel\")\n932\t        alerts = list(aq[:page_limit])\n933\t\n934\t    flips: list[Flip] = []\n935\t    if kinds is None or \"flip\" in kinds:\n936\t        fq = check.flip_set.order_by(\"-created\")\n937\t        fq = fq.filter(created__gte=start, created__lte=end)\n938\t        flips = list(fq[:page_limit])\n939\t\n940\t    events = pings + alerts + flips\n941\t    # Sort events by the timestamp.\n942\t    # If timestamps are equal, put flips chronologically after pings\n943\t    events.sort(key=lambda el: (el.created, isinstance(el, Flip)), reverse=True)\n944\t    return events[:page_limit]\n945\t\n946\t\n947\t@login_required\n948\tdef log(request: AuthenticatedHttpRequest, code: UUID) -> HttpResponse:\n949\t    check, rw = _get_check_for_user(request, code, preload_owner_profile=True)\n950\t\n951\t    smin = check.created\n952\t    smax = now()\n953\t    oldest_ping = check.visible_pings.order_by(\"n\").first()\n954\t    if oldest_ping:\n955\t        smin = max(smin, oldest_ping.created)\n956\t\n957\t    events = _get_events(check, 1000, start=smin, end=smax)\n958\t    ctx = {\n959\t        \"page\": \"log\",\n960\t        \"project\": check.project,\n961\t        \"check\": check,\n962\t        \"min\": smin,\n963\t        \"max\": smax,\n964\t        \"events\": events,\n965\t        \"oldest_ping\": oldest_ping,\n966\t        \"tz_switches\": _tz_switches(request.profile, check),\n967\t    }\n968\t\n969\t    if events:\n970\t        # A full precision timestamp of the most recent event.\n971\t        # This will be used client-side for fetching live updates to specify\n972\t        # \"return any events after *this* point\".\n973\t        ctx[\"last_event_timestamp\"] = events[0].created.timestamp()\n974\t\n975\t    return render(request, \"front/log.html\", ctx)\n976\t\n977\t\n978\tdef _tz_switches(profile: Profile, check: Check) -> list[str]:\n979\t    switches = [\"UTC\"]\n980\t    if profile.tz not in switches:\n981\t        switches.append(profile.tz)\n982\t    if check.kind in (\"cron\", \"oncalendar\") and check.tz not in switches:\n983\t        switches.append(check.tz)\n984\t    return switches\n985\t\n986\t\n987\t@login_required\n988\tdef details(request: AuthenticatedHttpRequest, code: UUID) -> HttpResponse:\n989\t    _refresh_last_active_date(request)\n990\t    check, rw = _get_check_for_user(request, code, preload_owner_profile=True)\n991\t\n992\t    if request.GET.get(\"urls\") in (\"uuid\", \"slug\") and rw:\n993\t        check.project.show_slugs = request.GET[\"urls\"] == \"slug\"\n994\t        check.project.save()\n995\t\n996\t    all_channels = check.project.channel_set.order_by(\"created\")"
      }
