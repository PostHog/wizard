        "content": "1\t\"\"\"\n2\tDjango settings for healthchecks project.\n3\t\n4\tFor the full list of settings and their values, see\n5\thttps://docs.djangoproject.com/en/4.2/ref/settings/\n6\t\"\"\"\n7\t\n8\tfrom __future__ import annotations\n9\t\n10\timport os\n11\tfrom collections.abc import Mapping\n12\tfrom pathlib import Path\n13\tfrom typing import Any, overload\n14\tfrom urllib.parse import urlparse\n15\t\n16\timport django_stubs_ext\n17\tfrom django.http.request import split_domain_port\n18\t\n19\tdjango_stubs_ext.monkeypatch()\n20\tBASE_DIR = Path(__file__).resolve().parent.parent\n21\t\n22\t\n23\tdef envbool(s: str, default: str) -> bool:\n24\t    v = os.getenv(s, default=default)\n25\t    if v not in (\"\", \"True\", \"False\"):\n26\t        msg = f\"Unexpected value {s}={v}, use 'True' or 'False'\"\n27\t        raise Exception(msg)\n28\t    return v == \"True\"\n29\t\n30\t\n31\tdef envint(s: str, default: str) -> int | None:\n32\t    v = os.getenv(s, default)\n33\t    if v == \"None\":\n34\t        return None\n35\t\n36\t    return int(v)\n37\t\n38\t\n39\t@overload\n40\tdef envsecret(s: str) -> str | None: ...\n41\t\n42\t\n43\t@overload\n44\tdef envsecret(s: str, default: str) -> str: ...\n45\t\n46\t\n47\tdef envsecret(s: str, default: str | None = None) -> str | None:\n48\t    \"\"\"Load a secret from an environment variable or from the filesystem.\n49\t\n50\t    This function either reads the secret from a file (if s + \"_FILE\" environment\n51\t    variable has a non-empty value), or calls os.getenv().\n52\t\n53\t    \"\"\"\n54\t\n55\t    if secret_path := os.getenv(s + \"_FILE\"):\n56\t        p = Path(secret_path)\n57\t        if not p.is_file():\n58\t            # If the _FILE env var has a non-empty value then the value *must*\n59\t            # be a path to a readable file. If we cannot access the file then we\n60\t            # fail loudly\n61\t            raise Exception(f\"Error reading {s}_FILE ({secret_path})\")\n62\t        return p.read_text().strip()\n63\t\n64\t    return os.getenv(s, default)\n65\t\n66\t\n67\tSECRET_KEY = envsecret(\"SECRET_KEY\", \"---\")\n68\tMETRICS_KEY = os.getenv(\"METRICS_KEY\")\n69\tDEBUG = envbool(\"DEBUG\", \"True\")\n70\tDEFAULT_FROM_EMAIL = os.getenv(\"DEFAULT_FROM_EMAIL\", \"healthchecks@example.org\")\n71\tSUPPORT_EMAIL = os.getenv(\"SUPPORT_EMAIL\")\n72\tUSE_PAYMENTS = envbool(\"USE_PAYMENTS\", \"False\")\n73\tREGISTRATION_OPEN = envbool(\"REGISTRATION_OPEN\", \"True\")\n74\tif admins := os.getenv(\"ADMINS\"):\n75\t    ADMINS = admins.split(\",\")\n76\t\n77\tif v := os.getenv(\"SECURE_PROXY_SSL_HEADER\"):\n78\t    SECURE_PROXY_SSL_HEADER = tuple(v.split(\",\", maxsplit=1))\n79\t\n80\t\n81\tVERSION = \"\"\n82\t\n83\twith (BASE_DIR / \"CHANGELOG.md\").open(encoding=\"utf-8\") as f:\n84\t    for line in f.readlines():\n85\t        if line.startswith(\"## v\"):\n86\t            VERSION = line.split()[1]\n87\t            break\n88\t\n89\t\n90\tINSTALLED_APPS = (\n91\t    \"hc.accounts\",\n92\t    \"django.contrib.admin\",\n93\t    \"django.contrib.auth\",\n94\t    \"django.contrib.contenttypes\",\n95\t    \"django.contrib.humanize\",\n96\t    \"django.contrib.sessions\",\n97\t    \"django.contrib.messages\",\n98\t    \"django.contrib.staticfiles\",\n99\t    \"compressor\",\n100\t    \"hc.api\",\n101\t    \"hc.front\",\n102\t    \"hc.logs\",\n103\t    \"hc.payments\",\n104\t    \"hc.integrations.apprise\",\n105\t    \"hc.integrations.call\",\n106\t    \"hc.integrations.discord\",\n107\t    \"hc.integrations.email\",\n108\t    \"hc.integrations.github\",\n109\t    \"hc.integrations.googlechat\",\n110\t    \"hc.integrations.gotify\",\n111\t    \"hc.integrations.group\",\n112\t    \"hc.integrations.matrix\",\n113\t    \"hc.integrations.mattermost\",\n114\t    \"hc.integrations.msteamsw\",\n115\t    \"hc.integrations.ntfy\",\n116\t    \"hc.integrations.opsgenie\",\n117\t    \"hc.integrations.pagertree\",\n118\t    \"hc.integrations.pd\",\n119\t    \"hc.integrations.po\",\n120\t    \"hc.integrations.prometheus\",\n121\t    \"hc.integrations.pushbullet\",\n122\t    \"hc.integrations.rocketchat\",\n123\t    \"hc.integrations.shell\",\n124\t    \"hc.integrations.signal\",\n125\t    \"hc.integrations.slack\",\n126\t    \"hc.integrations.sms\",\n127\t    \"hc.integrations.spike\",\n128\t    \"hc.integrations.telegram\",\n129\t    \"hc.integrations.trello\",\n130\t    \"hc.integrations.victorops\",\n131\t    \"hc.integrations.webhook\",\n132\t    \"hc.integrations.whatsapp\",\n133\t    \"hc.integrations.zulip\",\n134\t)\n135\t\n136\t\n137\tMIDDLEWARE = [\n138\t    \"django.middleware.security.SecurityMiddleware\",\n139\t    \"whitenoise.middleware.WhiteNoiseMiddleware\",\n140\t    \"django.contrib.sessions.middleware.SessionMiddleware\",\n141\t    \"django.middleware.common.CommonMiddleware\",\n142\t    \"django.middleware.csrf.CsrfViewMiddleware\",\n143\t    \"django.contrib.auth.middleware.AuthenticationMiddleware\",\n144\t    \"hc.accounts.middleware.CustomHeaderMiddleware\",\n145\t    \"django.contrib.messages.middleware.MessageMiddleware\",\n146\t    \"django.middleware.clickjacking.XFrameOptionsMiddleware\",\n147\t    \"hc.accounts.middleware.TeamAccessMiddleware\",\n148\t]\n149\t\n150\tif envbool(\"USE_GZIP_MIDDLEWARE\", \"False\"):\n151\t    MIDDLEWARE.append(\"django.middleware.gzip.GZipMiddleware\")\n152\t\n153\tAUTHENTICATION_BACKENDS = [\n154\t    \"hc.accounts.backends.EmailBackend\",\n155\t    \"hc.accounts.backends.ProfileBackend\",\n156\t]\n157\t\n158\tREMOTE_USER_HEADER = os.getenv(\"REMOTE_USER_HEADER\")\n159\tif REMOTE_USER_HEADER:\n160\t    AUTHENTICATION_BACKENDS = [\"hc.accounts.backends.CustomHeaderBackend\"]\n161\t\n162\tROOT_URLCONF = \"hc.urls\"\n163\t\n164\tTEMPLATES = [\n165\t    {\n166\t        \"BACKEND\": \"django.template.backends.django.DjangoTemplates\",\n167\t        \"DIRS\": [BASE_DIR / \"templates\"],\n168\t        \"APP_DIRS\": True,\n169\t        \"OPTIONS\": {\n170\t            \"context_processors\": [\n171\t                \"django.template.context_processors.debug\",\n172\t                \"django.template.context_processors.request\",\n173\t                \"django.contrib.auth.context_processors.auth\",\n174\t                \"django.contrib.messages.context_processors.messages\",\n175\t                \"hc.front.context_processors.branding\",\n176\t                \"hc.payments.context_processors.payments\",\n177\t            ]\n178\t        },\n179\t    }\n180\t]\n181\t\n182\t# Extend Django logging to log unhandled exceptions\n183\t# and all logs from hc.* loggers to the database.\n184\tLOGGING = {\n185\t    \"version\": 1,\n186\t    \"disable_existing_loggers\": False,\n187\t    \"handlers\": {\n188\t        \"db\": {\n189\t            \"level\": \"DEBUG\",\n190\t            \"class\": \"hc.logs.Handler\",\n191\t        },\n192\t    },\n193\t    \"loggers\": {\n194\t        \"django.request\": {\"level\": \"ERROR\", \"handlers\": [\"db\"]},\n195\t        \"hc\": {\"level\": \"DEBUG\", \"handlers\": [\"db\"]},\n196\t    },\n197\t}\n198\t\n199\tWSGI_APPLICATION = \"hc.wsgi.application\"\n200\tTEST_RUNNER = \"hc.api.tests.CustomRunner\"\n201\t\n202\t\n203\t# Default database engine is SQLite. So one can just check out code,\n204\t# install requirements.txt and do manage.py runserver and it works\n205\tDEFAULT_AUTO_FIELD = \"django.db.models.AutoField\"\n206\tDATABASES: Mapping[str, Any] = {\n207\t    \"default\": {\n208\t        \"ENGINE\": \"django.db.backends.sqlite3\",\n209\t        \"NAME\": os.getenv(\"DB_NAME\", BASE_DIR / \"hc.sqlite\"),\n210\t        \"OPTIONS\": {\n211\t            \"init_command\": \"PRAGMA busy_timeout = 5000;\",\n212\t            \"transaction_mode\": \"IMMEDIATE\",\n213\t        },\n214\t    }\n215\t}\n216\t\n217\t# You can switch database engine to postgres or mysql using environment\n218\t# variable 'DB'. Travis CI does this.\n219\tif os.getenv(\"DB\") == \"postgres\":\n220\t    DATABASES = {\n221\t        \"default\": {\n222\t            \"ENGINE\": \"django.db.backends.postgresql\",\n223\t            \"HOST\": os.getenv(\"DB_HOST\", \"\"),\n224\t            \"PORT\": os.getenv(\"DB_PORT\", \"\"),\n225\t            \"NAME\": os.getenv(\"DB_NAME\", \"hc\"),\n226\t            \"USER\": os.getenv(\"DB_USER\", \"postgres\"),\n227\t            \"PASSWORD\": envsecret(\"DB_PASSWORD\", \"\"),\n228\t            \"CONN_MAX_AGE\": envint(\"DB_CONN_MAX_AGE\", \"0\"),\n229\t            \"TEST\": {\"CHARSET\": \"UTF8\"},\n230\t            \"OPTIONS\": {\n231\t                \"application_name\": \"hc\",\n232\t                \"sslmode\": os.getenv(\"DB_SSLMODE\", \"prefer\"),\n233\t                \"target_session_attrs\": os.getenv(\n234\t                    \"DB_TARGET_SESSION_ATTRS\", \"read-write\"\n235\t                ),\n236\t            },\n237\t        }\n238\t    }\n239\t\n240\tif os.getenv(\"DB\") in [\"mysql\", \"mariadb\"]:\n241\t    DATABASES = {\n242\t        \"default\": {\n243\t            \"ENGINE\": \"django.db.backends.mysql\",\n244\t            \"HOST\": os.getenv(\"DB_HOST\", \"\"),\n245\t            \"PORT\": os.getenv(\"DB_PORT\", \"\"),\n246\t            \"NAME\": os.getenv(\"DB_NAME\", \"hc\"),\n247\t            \"USER\": os.getenv(\"DB_USER\", \"root\"),\n248\t            \"PASSWORD\": envsecret(\"DB_PASSWORD\", \"\"),\n249\t            \"TEST\": {\"CHARSET\": \"UTF8\"},\n250\t        }\n251\t    }\n252\t\n253\tUSE_TZ = True\n254\tTIME_ZONE = \"UTC\"\n255\tUSE_I18N = False\n256\t\n257\tSITE_ROOT = os.getenv(\"SITE_ROOT\", \"http://localhost:8000\").removesuffix(\"/\")\n258\tSITE_NAME = os.getenv(\"SITE_NAME\", \"Mychecks\")\n259\tSITE_LOGO_URL = os.getenv(\"SITE_LOGO_URL\")\n260\tMASTER_BADGE_LABEL = os.getenv(\"MASTER_BADGE_LABEL\", SITE_NAME)\n261\tPING_ENDPOINT = os.getenv(\"PING_ENDPOINT\", SITE_ROOT + \"/ping/\")\n262\tPING_EMAIL_DOMAIN = os.getenv(\"PING_EMAIL_DOMAIN\", \"localhost\")\n263\tPING_BODY_LIMIT = envint(\"PING_BODY_LIMIT\", \"10000\")\n264\t# If PING_BODY_LIMIT is higher than the default value for DATA_UPLOAD_MAX_MEMORY_SIZE,\n265\t# then we need to bump up DATA_UPLOAD_MAX_MEMORY_SIZE too:\n266\tif PING_BODY_LIMIT and PING_BODY_LIMIT > 2621440:\n267\t    DATA_UPLOAD_MAX_MEMORY_SIZE = PING_BODY_LIMIT\n268\t_site_root_parts = urlparse(SITE_ROOT)\n269\tLOGIN_URL = f\"{_site_root_parts.path}/accounts/login/\"\n270\tSTATIC_URL = f\"{_site_root_parts.path}/static/\"\n271\tif v := os.getenv(\"ALLOWED_HOSTS\"):\n272\t    # If ALLOWED_HOSTS is set in environment, use it\n273\t    ALLOWED_HOSTS = v.split(\",\")\n274\telse:\n275\t    # Otherwise, populate it with the domain from SITE_ROOT\n276\t    domain, _ = split_domain_port(_site_root_parts.netloc)\n277\t    ALLOWED_HOSTS = [domain]\n278\t\n279\tSTATICFILES_DIRS = [BASE_DIR / \"static\"]\n280\tSTATIC_ROOT = BASE_DIR / \"static-collected\"\n281\tSTATICFILES_FINDERS = (\n282\t    \"django.contrib.staticfiles.finders.FileSystemFinder\",\n283\t    \"django.contrib.staticfiles.finders.AppDirectoriesFinder\",\n284\t    \"compressor.finders.CompressorFinder\",\n285\t)\n286\tCOMPRESS_OFFLINE = True\n287\tCOMPRESS_CSS_HASHING_METHOD = \"content\"\n288\tCOMPRESS_STORAGE = \"compressor.storage.GzipCompressorFileStorage\"\n289\t# Use CssRelativeFilter instead of CssAbsoluteFilter to fix\n290\t# icon font loading when serving Healthchecks from a subdirectory\n291\tCOMPRESS_FILTERS = {\n292\t    \"css\": [\n293\t        \"compressor.filters.css_default.CssRelativeFilter\",\n294\t        \"compressor.filters.cssmin.rCSSMinFilter\",\n295\t    ],\n296\t    \"js\": [],\n297\t}\n298\t\n299\t\n300\tdef immutable_file_test(path: Any, url: str) -> bool:\n301\t    return \"/static/CACHE/\" in url or \"/static/fonts/\" in url\n302\t\n303\t\n304\tWHITENOISE_IMMUTABLE_FILE_TEST = immutable_file_test\n305\t\n306\t# SMTP credentials for sending email\n307\tEMAIL_HOST = os.getenv(\"EMAIL_HOST\", \"\")\n308\tEMAIL_PORT = envint(\"EMAIL_PORT\", \"587\")\n309\tEMAIL_HOST_USER = os.getenv(\"EMAIL_HOST_USER\", \"\")\n310\tEMAIL_HOST_PASSWORD = envsecret(\"EMAIL_HOST_PASSWORD\", \"\")\n311\tEMAIL_USE_TLS = envbool(\"EMAIL_USE_TLS\", \"True\")\n312\tEMAIL_USE_SSL = envbool(\"EMAIL_USE_SSL\", \"False\")\n313\tEMAIL_USE_VERIFICATION = envbool(\"EMAIL_USE_VERIFICATION\", \"True\")\n314\tEMAIL_MAIL_FROM_TMPL = os.getenv(\"EMAIL_MAIL_FROM_TMPL\", \"\")\n315\t\n316\t# WebAuthn\n317\tRP_ID = os.getenv(\"RP_ID\")\n318\t\n319\t# Object storage credentials for storing large ping bodies.\n320\t# (Optional. If not specified, will store ping bodies in the database.)\n321\tS3_ACCESS_KEY = os.getenv(\"S3_ACCESS_KEY\")\n322\tS3_SECRET_KEY = envsecret(\"S3_SECRET_KEY\")\n323\tS3_ENDPOINT = os.getenv(\"S3_ENDPOINT\")\n324\tS3_REGION = os.getenv(\"S3_REGION\")\n325\tS3_BUCKET = os.getenv(\"S3_BUCKET\")\n326\tS3_TIMEOUT = envint(\"S3_TIMEOUT\", \"60\")\n327\tS3_SECURE = envbool(\"S3_SECURE\", \"True\")\n328\t\n329\t# To enable statsd metric collection, set STATSD_HOST=\"host:hostport\"\n330\t# (example: \"localhost:8125\")\n331\tSTATSD_HOST = os.getenv(\"STATSD_HOST\")\n332\t\n333\t# Integrations\n334\t\n335\t# Apprise\n336\tAPPRISE_ENABLED = envbool(\"APPRISE_ENABLED\", \"False\")\n337\t\n338\t# Discord integration\n339\tDISCORD_CLIENT_ID = os.getenv(\"DISCORD_CLIENT_ID\")\n340\tDISCORD_CLIENT_SECRET = envsecret(\"DISCORD_CLIENT_SECRET\")\n341\t\n342\t# GitHub Issues\n343\tGITHUB_CLIENT_ID = os.getenv(\"GITHUB_CLIENT_ID\")\n344\tGITHUB_CLIENT_SECRET = envsecret(\"GITHUB_CLIENT_SECRET\")\n345\tGITHUB_PRIVATE_KEY = envsecret(\"GITHUB_PRIVATE_KEY\")\n346\tGITHUB_PUBLIC_LINK = os.getenv(\"GITHUB_PUBLIC_LINK\")\n347\t\n348\t# Matrix\n349\tMATRIX_HOMESERVER = os.getenv(\"MATRIX_HOMESERVER\")\n350\tMATRIX_USER_ID = os.getenv(\"MATRIX_USER_ID\")\n351\tMATRIX_ACCESS_TOKEN = envsecret(\"MATRIX_ACCESS_TOKEN\")\n352\t\n353\t# Mattermost\n354\tMATTERMOST_ENABLED = envbool(\"MATTERMOST_ENABLED\", \"True\")\n355\t\n356\t# MS Teams\n357\tMSTEAMS_ENABLED = envbool(\"MSTEAMS_ENABLED\", \"True\")\n358\t\n359\t# ntfy.sh\n360\tNTFY_SH_TOKEN = envsecret(\"NTFY_SH_TOKEN\")\n361\t\n362\t# Opsgenie\n363\tOPSGENIE_ENABLED = envbool(\"OPSGENIE_ENABLED\", \"True\")\n364\t\n365\t# PagerTree\n366\tPAGERTREE_ENABLED = envbool(\"PAGERTREE_ENABLED\", \"True\")\n367\t\n368\t# PagerDuty\n369\tPD_ENABLED = envbool(\"PD_ENABLED\", \"True\")\n370\tPD_APP_ID = os.getenv(\"PD_APP_ID\")\n371\t\n372\t# Prometheus\n373\tPROMETHEUS_ENABLED = envbool(\"PROMETHEUS_ENABLED\", \"True\")\n374\t\n375\t# Pushover integration\n376\tPUSHOVER_API_TOKEN = envsecret(\"PUSHOVER_API_TOKEN\")\n377\tPUSHOVER_SUBSCRIPTION_URL = os.getenv(\"PUSHOVER_SUBSCRIPTION_URL\")\n378\tPUSHOVER_EMERGENCY_RETRY_DELAY = int(os.getenv(\"PUSHOVER_EMERGENCY_RETRY_DELAY\", \"300\"))\n379\tPUSHOVER_EMERGENCY_EXPIRATION = int(os.getenv(\"PUSHOVER_EMERGENCY_EXPIRATION\", \"86400\"))\n380\t\n381\t# Pushbullet integration\n382\tPUSHBULLET_CLIENT_ID = os.getenv(\"PUSHBULLET_CLIENT_ID\")\n383\tPUSHBULLET_CLIENT_SECRET = envsecret(\"PUSHBULLET_CLIENT_SECRET\")\n384\t\n385\t# Rocket.Chat\n386\tROCKETCHAT_ENABLED = envbool(\"ROCKETCHAT_ENABLED\", \"True\")\n387\t\n388\t# Local shell commands\n389\tSHELL_ENABLED = envbool(\"SHELL_ENABLED\", \"False\")\n390\t\n391\t# Signal\n392\tSIGNAL_CLI_SOCKET = os.getenv(\"SIGNAL_CLI_SOCKET\")\n393\t\n394\t# Slack integration\n395\tSLACK_CLIENT_ID = os.getenv(\"SLACK_CLIENT_ID\")\n396\tSLACK_CLIENT_SECRET = envsecret(\"SLACK_CLIENT_SECRET\")\n397\tSLACK_ENABLED = envbool(\"SLACK_ENABLED\", \"True\")\n398\t\n399\t# Spike.sh\n400\tSPIKE_ENABLED = envbool(\"SPIKE_ENABLED\", \"True\")\n401\t\n402\t# Telegram integration -- override in local_settings.py\n403\tTELEGRAM_BOT_NAME = os.getenv(\"TELEGRAM_BOT_NAME\", \"ExampleBot\")\n404\tTELEGRAM_TOKEN = envsecret(\"TELEGRAM_TOKEN\")\n405\t\n406\t# SMS and WhatsApp (Twilio) integration\n407\tTWILIO_ACCOUNT = os.getenv(\"TWILIO_ACCOUNT\")\n408\tTWILIO_AUTH = envsecret(\"TWILIO_AUTH\")\n409\tTWILIO_FROM = os.getenv(\"TWILIO_FROM\")\n410\tTWILIO_MESSAGING_SERVICE_SID = os.getenv(\"TWILIO_MESSAGING_SERVICE_SID\")\n411\tTWILIO_USE_WHATSAPP = envbool(\"TWILIO_USE_WHATSAPP\", \"False\")\n412\tWHATSAPP_DOWN_CONTENT_SID = os.getenv(\"WHATSAPP_DOWN_CONTENT_SID\")\n413\tWHATSAPP_UP_CONTENT_SID = os.getenv(\"WHATSAPP_UP_CONTENT_SID\")\n414\t\n415\t# Trello (https://trello.com/app-key)\n416\tTRELLO_APP_KEY = envsecret(\"TRELLO_APP_KEY\")\n417\t\n418\t# VictorOps\n419\tVICTOROPS_ENABLED = envbool(\"VICTOROPS_ENABLED\", \"True\")\n420\t\n421\t# Webhooks\n422\tWEBHOOKS_ENABLED = envbool(\"WEBHOOKS_ENABLED\", \"True\")\n423\tINTEGRATIONS_ALLOW_PRIVATE_IPS = envbool(\"INTEGRATIONS_ALLOW_PRIVATE_IPS\", \"False\")\n424\t\n425\t# Zulip\n426\tZULIP_ENABLED = envbool(\"ZULIP_ENABLED\", \"True\")\n427\t\n428\t# Read additional configuration from hc/local_settings.py if it exists\n429\tif (BASE_DIR / \"hc/local_settings.py\").exists():\n430\t    from .local_settings import *  # noqa: F403\n431\t"
