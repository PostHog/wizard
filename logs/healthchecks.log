2\t    \"hc-add-pushover\",\n53\t    \"hc-add-telegram\",\n54\t    \"hc-project-settings\",\n55\t    \"hc-uncloak\",\n56\t)\n57\t\n58\t\n59\tdef _allow_redirect(redirect_url: str | None) -> bool:\n60\t    if not redirect_url:\n61\t        return False\n62\t\n63\t    parsed = urlparse(redirect_url)\n64\t    if parsed.netloc:\n65\t        # Allow redirects only to relative URLs\n66\t        return False\n67\t\n68\t    try:\n69\t        match = resolve(parsed.path)\n70\t    except Resolver404:\n71\t        return False\n72\t\n73\t    return match.url_name in POST_LOGIN_ROUTES\n74\t\n75\t\n76\tdef _make_user(email: str, tz: str | None = None, with_project: bool = True) -> User:\n77\t    username = str(uuid4())[:30]\n78\t    user = User(username=username, email=email)\n79\t    user.set_unusable_password()\n80\t    user.save()\n81\t\n82\t    project = None\n83\t    if with_project:\n84\t        project = Project(owner=user)\n85\t        project.badge_key = user.username\n86\t        project.save()\n87\t\n88\t        check = Check(project=project)\n89\t        check.name = \"My First Check\"\n90\t        check.slug = \"my-first-check\"\n91\t        check.save()\n92\t\n93\t        channel = Channel(project=project)\n94\t        channel.kind = \"email\"\n95\t        channel.value = email\n96\t        channel.email_verified = True\n97\t        channel.save()\n98\t\n99\t        channel.checks.add(check)\n100\t\n101\t    # Ensure a profile gets created\n102\t    profile = Profile.objects.for_user(user)\n103\t    if tz:\n104\t        profile.tz = tz\n105\t        profile.save()\n106\t\n107\t    return user\n108\t\n109\t\n110\tdef _redirect_after_login(request: HttpRequest) -> HttpResponse:\n111\t    \"\"\"Redirect to the URL indicated in ?next= query parameter.\"\"\"\n112\t\n113\t    redirect_url = request.GET.get(\"next\")\n114\t    if redirect_url and _allow_redirect(redirect_url):\n115\t        return redirect(redirect_url)\n116\t\n117\t    assert isinstance(request.user, User)\n118\t    if request.user.project_set.count() == 1:\n119\t        project = request.user.project_set.get()\n120\t        return redirect(\"hc-checks\", project.code)\n121\t\n122\t    return redirect(\"hc-index\")\n123\t\n124\t\n125\tdef _check_2fa(request: HttpRequest, user: User) -> HttpResponse:\n126\t    have_keys = user.credentials.exists()\n127\t    profile = Profile.objects.for_user(user)\n128\t    if have_keys or profile.totp:\n129\t        # We have verified user's password or token, and now must\n130\t        # verify their security key. We store the following in user's session:\n131\t        # - user.id, to look up the user in the login_webauthn view\n132\t        # - user.email, to make sure email was not changed between the auth steps\n133\t        # - timestamp, to limit the max time between the auth steps\n134\t        request.session[\"2fa_user\"] = [user.id, user.email, int(time.time())]\n135\t\n136\t        query = {}\n137\t        if _allow_redirect(request.GET.get(\"next\")):\n138\t            query[\"next\"] = request.GET[\"next\"]\n139\t\n140\t        route = \"hc-login-webauthn\" if have_keys else \"hc-login-totp\"\n141\t        path = reverse(route, query=query)\n142\t        return redirect(path)\n143\t\n144\t    auth_login(request, user)\n145\t    return _redirect_after_login(request)\n146\t\n147\t\n148\tdef _set_autologin_cookie(response: HttpResponse) -> None:\n149\t    # check_token looks for this cookie to decide if\n150\t    # it needs to do the extra POST step.\n151\t    response.set_cookie(\n152\t        \"auto-login\",\n153\t        \"1\",\n154\t        max_age=300,\n155\t        httponly=True,\n156\t        samesite=\"Lax\",\n157\t        secure=bool(settings.SESSION_COOKIE_SECURE),\n158\t    )\n159\t\n160\t\n161\t@sensitive_post_parameters()\n162\tdef login(request: HttpRequest) -> HttpResponse:\n163\t    form = forms.PasswordLoginForm()\n164\t    magic_form = forms.EmailLoginForm()\n165\t    if request.method == \"POST\":\n166\t        if request.POST.get(\"action\") == \"login\":\n167\t            form = forms.PasswordLoginForm(request.POST)\n168\t            if form.is_valid():\n169\t                assert isinstance(form.user, User)\n170\t                return _check_2fa(request, form.user)\n171\t\n172\t        else:\n173\t            magic_form = forms.EmailLoginForm(request)\n174\t            if magic_form.is_valid():\n175\t                redirect_url = request.GET.get(\"next\")\n176\t                if not _allow_redirect(redirect_url):\n177\t                    redirect_url = None\n178\t\n179\t                if magic_form.user:\n180\t                    profile = Profile.objects.for_user(magic_form.user)\n181\t                    profile.send_instant_login_link(redirect_url=redirect_url)\n182\t\n183\t                response = redirect(\"hc-login-link-sent\")\n184\t                _set_autologin_cookie(response)\n185\t                return response\n186\t\n187\t    if request.user.is_authenticated:\n188\t        return _redirect_after_login(request)\n189\t\n190\t    bad_link = request.session.pop(\"bad_link\", None)\n191\t    ctx = {\n192\t        \"page\": \"login\",\n193\t        \"form\": form,\n194\t        \"magic_form\": magic_form,\n195\t        \"bad_link\": bad_link,\n196\t        \"registration_open\": settings.REGISTRATION_OPEN,\n197\t        \"support_email\": settings.SUPPORT_EMAIL,\n198\t        \"account_closed\": \"account-closed\" in request.GET,\n199\t        \"use_magic_form\": bool(settings.EMAIL_HOST),\n200\t    }\n201\t    return render(request, \"accounts/login.html\", ctx)\n202\t\n203\t\n204\t@require_POST\n205\tdef logout(request: HttpRequest) -> HttpResponse:\n206\t    auth_logout(request)\n207\t    return redirect(\"hc-index\")\n208\t\n209\t\n210\tdef signup_csrf(request: HttpRequest) -> HttpResponse:\n211\t    if not settings.REGISTRATION_OPEN or request.user.is_authenticated:\n212\t        return HttpResponseForbidden()\n213\t\n214\t    return HttpResponse(csrf.get_token(request))\n215\t\n216\t\n217\t@require_POST\n218\tdef signup(request: HttpRequest) -> HttpResponse:\n219\t    if not settings.REGISTRATION_OPEN or request.user.is_authenticated:\n220\t        return HttpResponseForbidden()\n221\t\n222\t    ctx: dict[str, object] = {}\n223\t    form = forms.SignupForm(request)\n224\t    if form.is_valid():\n225\t        email = form.cleaned_data[\"identity\"]\n226\t        try:\n227\t            user = User.objects.get(email=email)\n228\t            # Sometimes existing users forget they already have an account.\n229\t            # They use the signup form and are confused why no email arrives.\n230\t            # To avoid this confusion, if we see the user account already exists,\n231\t            # we will send them sign-in link even though they used the wrong form\n232\t            # (\"sign up\" instead of \"sign in\").\n233\t        except User.DoesNotExist:\n234\t            # If the user does not exist, create a new user account.\n235\t            tz = form.cleaned_data[\"tz\"]\n236\t            user = _make_user(email, tz)\n237\t\n238\t        profile = Profile.objects.for_user(user)\n239\t        profile.send_instant_login_link()\n240\t    else:\n241\t        ctx = {\"form\": form}\n242\t\n243\t    response = render(request, \"accounts/signup_result.html\", ctx)\n244\t    if \"form\" not in ctx:\n245\t        _set_autologin_cookie(response)\n246\t\n247\t    return response\n248\t\n249\t\n250\tdef login_link_sent(request: HttpRequest) -> HttpResponse:\n251\t    return render(request, \"accounts/login_link_sent.html\")\n252\t\n253\t\n254\tdef check_token(\n255\t    request: HttpRequest, username: str, token: str, new_email: str | None = None\n256\t) -> HttpResponse:\n257\t    if request.user.is_authenticated:\n258\t        auth_logout(request)\n259\t\n260\t    # Some email servers open links in emails to check for malicious content.\n261\t    # To work around this, we sign user in if the method is POST\n262\t    # *or* if the browser presents a cookie we had set when sending the login link.\n263\t    #\n264\t    # If the method is GET and the auto-login cookie isn't present, we serve\n265\t    # a HTML form with a submit button.\n266\t    if request.method != \"POST\" and \"auto-login\" not in request.COOKIES:\n267\t        return render(request, \"accounts/check_token_submit.html\")\n268\t\n269\t    user = authenticate(username=username, token=token)\n270\t    if user is not None and user.is_active:\n271\t        if new_email:\n272\t            if User.objects.filter(email=new_email).exists():\n273\t                request.session[\"bad_link\"] = True\n274\t                return redirect(\"hc-login\")\n275\t\n276\t            user.email = new_email\n277\t            user.save()\n278\t\n279\t        user.profile.token = \"\"\n280\t        user.profile.save()\n281\t        return _check_2fa(request, user)\n282\t\n283\t    request.session[\"bad_link\"] = True\n284\t    return redirect(\"hc-login\")\n285\t\n286\t\n287\t@login_required\n288\tdef profile(request: AuthenticatedHttpRequest) -> HttpResponse:\n289\t    profile = request.profile\n290\t\n291\t    ctx = {\n292\t        \"page\": \"profile\",\n293\t        \"profile\": profile,\n294\t        \"my_projects_status\": \"default\",\n295\t        \"2fa_status\": \"default\",\n296\t        \"tz_status\": \"default\",\n297\t        \"added_credential_name\": request.session.pop(\"added_credential_name\", \"\"),\n298\t        \"removed_credential_name\": request.session.pop(\"removed_credential_name\", \"\"),\n299\t        \"enabled_totp\": request.session.pop(\"enabled_totp\", False),\n300\t        \"disabled_totp\": request.session.pop(\"disabled_totp\", False),\n301\t        \"credentials\": list(request.user.credentials.order_by(\"id\")),\n302\t        \"use_webauthn\": settings.RP_ID,\n303\t        \"timezones\": all_timezones,\n304\t    }\n305\t\n306\t    if ctx[\"added_credential_name\"] or ctx[\"enabled_totp\"]:\n307\t        ctx[\"2fa_status\"] = \"success\"\n308\t\n309\t    if ctx[\"removed_credential_name\"] or ctx[\"disabled_totp\"]:\n310\t        ctx[\"2fa_status\"] = \"info\"\n311\t\n312\t    if request.session.pop(\"changed_password\", False):\n313\t        ctx[\"changed_password\"] = True\n314\t        ctx[\"email_password_status\"] = \"success\"\n315\t\n316\t    if request.method == \"POST\" and \"leave_project\" in request.POST:\n317\t        leave_form = forms.LeaveForm(request.POST)\n318\t        if not leave_form.is_valid():\n319\t            return HttpResponseBadRequest()\n320\t\n321\t        try:\n322\t            project = Project.objects.get(\n323\t                code=leave_form.cleaned_data[\"code\"], member__user=request.user\n324\t            )\n325\t        except Project.DoesNotExist:\n326\t            return HttpResponseBadRequest()\n327\t\n328\t        Member.objects.filter(project=project, user=request.user).delete()\n329\t\n330\t        ctx[\"left_project\"] = project\n331\t        ctx[\"my_projects_status\"] = \"info\"\n332\t\n333\t    if request.method == \"POST\" and \"tz\" in request.POST:\n334\t        form = forms.TzForm(request.POST)\n335\t        if form.is_valid():\n336\t            profile.tz = form.cleaned_data[\"tz\"]\n337\t            profile.save()\n338\t            ctx[\"tz_status\"] = \"info\"\n339\t            ctx[\"tz_updated\"] = True\n340\t\n341\t    ctx[\"ownerships\"] = request.user.project_set.order_by(Lower(\"name\"))\n342\t    ctx[\"memberships\"] = request.user.memberships.order_by(Lower(\"project__name\"))\n343\t    return render(request, \"accounts/profile.html\", ctx)\n344\t\n345\t\n346\t@login_required\n347\t@require_POST\n348\tdef add_project(request: AuthenticatedHttpRequest) -> HttpResponse:\n349\t    form = forms.ProjectNameForm(request.POST)\n350\t    if not form.is_valid():\n351\t        return HttpResponseBadRequest()\n352\t\n353\t    project = Project(owner=request.user)\n354\t    project.code = project.badge_key = str(uuid4())\n355\t    project.name = form.cleaned_data[\"name\"]\n356\t    project.save()\n357\t\n358\t    return redirect(\"hc-checks\", project.code)\n359\t\n360\t\n361\t@login_required\n362\tdef project(request: AuthenticatedHttpRequest, code: UUID) -> HttpResponse:\n363\t    project = get_object_or_404(Project, code=code)\n364\t    is_owner = project.owner_id == request.user.id\n365\t\n366\t    if request.user.is_superuser or is_owner:\n367\t        is_manager = True\n368\t        rw = True\n369\t    else:\n370\t        membership = get_object_or_404(Member, project=project, user=request.user)\n371\t        is_manager = membership.role == Member.Role.MANAGER\n372\t        rw = membership.is_rw\n373\t\n374\t    ctx = {\n375\t        \"page\": \"project\",\n376\t        \"rw\": rw,\n377\t        \"project\": project,\n378\t        \"is_owner\": is_owner,\n379\t        \"is_manager\": is_manager,\n380\t        \"show_api_keys\": \"show_api_keys\" in request.GET,\n381\t        \"enable_prometheus\": settings.PROMETHEUS_ENABLED is True,\n382\t    }\n383\t\n384\t    if request.method == \"POST\":\n385\t        if \"create_key\" in request.POST:\n386\t            if not rw:\n387\t                return HttpResponseForbidden()\n388\t\n389\t            if request.POST[\"create_key\"] == \"api_key\":\n390\t                ctx[\"new_key\"] = project.set_api_key()\n391\t            elif request.POST[\"create_key\"] == \"api_key_readonly\":\n392\t                ctx[\"new_key\"] = project.set_api_key_readonly()\n393\t            elif request.POST[\"create_key\"] == \"ping_key\":\n394\t                ctx[\"new_ping_key\"] = project.set_ping_key()\n395\t            project.save()\n396\t\n397\t            ctx[\"key_created\"] = True\n398\t            ctx[\"api_status\"] = \"success\"\n399\t        elif \"revoke_key\" in request.POST:\n400\t            if not rw:\n401\t                return HttpResponseForbidden()\n402\t\n403\t            if request.POST[\"revoke_key\"] == \"api_key\":\n404\t                project.api_key = \"\"\n405\t            elif request.POST[\"revoke_key\"] == \"api_key_readonly\":\n406\t                project.api_key_readonly = \"\"\n407\t            elif request.POST[\"revoke_key\"] == \"ping_key\":\n408\t                project.ping_key = None\n409\t            project.save()\n410\t\n411\t            ctx[\"key_revoked\"] = True\n412\t            ctx[\"api_status\"] = \"info\"\n413\t        elif \"invite_team_member\" in request.POST:\n414\t            if not is_manager:\n415\t                return HttpResponseForbidden()\n416\t\n417\t            invite_form = forms.InviteTeamMemberForm(request.POST)\n418\t            if invite_form.is_valid():\n419\t                email = invite_form.cleaned_data[\"email\"]\n420\t\n421\t                invite_suggestions = project.invite_suggestions()\n422\t                if not invite_suggestions.filter(email=email).exists():\n423\t                    # And are we not hitting a rate limit?\n424\t                    if not TokenBucket.authorize_invite(request.user):\n425\t                        return render(request, \"try_later.html\")\n426\t\n427\t                try:\n428\t                    user = User.objects.get(email=email)\n429\t                except User.DoesNotExist:\n430\t                    user = _make_user(email, with_project=False)\n431\t\n432\t                if project.invite(user, role=invite_form.cleaned_data[\"role\"]):\n433\t                    ctx[\"team_member_invited\"] = email\n434\t                    ctx[\"team_status\"] = \"success\"\n435\t                else:\n436\t                    ctx[\"team_member_duplicate\"] = email\n437\t                    ctx[\"team_status\"] = \"info\"\n438\t\n439\t        elif \"remove_team_member\" in request.POST:\n440\t            if not is_manager:\n441\t                return HttpResponseForbidden()\n442\t\n443\t            remove_form = forms.RemoveTeamMemberForm(request.POST)\n444\t            if remove_form.is_valid():\n445\t                q = User.objects.filter(\n446\t                    email=remove_form.cleaned_data[\"email\"],\n447\t                    memberships__project=project,\n448\t                )\n449\t                farewell_user = q.first()\n450\t                if farewell_user is None:\n451\t                    return HttpResponseBadRequest()\n452\t\n453\t                if farewell_user == request.user:\n454\t                    return HttpResponseBadRequest()\n455\t\n456\t                Member.objects.filter(project=project, user=farewell_user).delete()\n457\t\n458\t                ctx[\"team_member_removed\"] = remove_form.cleaned_data[\"email\"]\n459\t                ctx[\"team_status\"] = \"info\"\n460\t        elif \"set_project_name\" in request.POST:\n461\t            if not rw:\n462\t                return HttpResponseForbidden()\n463\t\n464\t            name_form = forms.ProjectNameForm(request.POST)\n465\t            if name_form.is_valid():\n466\t                project.name = name_form.cleaned_data[\"name\"]\n467\t                project.save()\n468\t\n469\t                ctx[\"project_name_updated\"] = True\n470\t                ctx[\"project_name_status\"] = \"success\"\n471\t\n472\t        elif \"transfer_project\" in request.POST:\n473\t            if not is_owner:\n474\t                return HttpResponseForbidden()\n475\t\n476\t            transfer_form = forms.TransferForm(request.POST)\n477\t            if transfer_form.is_valid():\n478\t                # Look up the proposed new owner\n479\t                email = transfer_form.cleaned_data[\"email\"]\n480\t                try:\n481\t                    membership = project.member_set.filter(user__email=email).get()\n482\t                except Member.DoesNotExist:\n483\t                    return HttpResponseBadRequest()\n484\t\n485\t                # Revoke any previous transfer requests\n486\t                project.member_set.update(transfer_request_date=None)\n487\t\n488\t                # Initiate the new request\n489\t                membership.transfer_request_date = now()\n490\t                membership.save()\n491\t\n492\t                # Send an email notification\n493\t                profile = Profile.objects.for_user(membership.user)\n494\t                profile.send_transfer_request(project)\n495\t\n496\t                ctx[\"transfer_initiated\"] = True\n497\t                ctx[\"transfer_status\"] = \"success\"\n498\t\n499\t        elif \"cancel_transfer\" in request.POST:\n500\t            if not is_owner:\n501\t                return HttpResponseForbidden()\n502\t\n503\t            project.member_set.update(transfer_request_date=None)\n504\t            ctx[\"transfer_cancelled\"] = True\n505\t            ctx[\"transfer_status\"] = \"success\"\n506\t\n507\t        elif \"accept_transfer\" in request.POST:\n508\t            tr = project.transfer_request()\n509\t            if not tr or tr.user != request.user:\n510\t                return HttpResponseForbidden()\n511\t\n512\t            if not tr.can_accept():\n513\t                return HttpResponseBadRequest()\n514\t\n515\t            with transaction.atomic():\n516\t                # 1. Reuse the existing membership, and change its user\n517\t                tr.user = project.owner\n518\t                tr.transfer_request_date = None\n519\t                # The previous owner becomes a regular member\n520\t                # (not readonly, not manager):\n521\t                tr.role = Member.Role.REGULAR\n522\t                tr.save()\n523\t\n524\t                # 2. Change project's owner\n525\t                project.owner = request.user\n526\t                project.save()\n527\t\n528\t            ctx[\"is_owner\"] = True\n529\t            ctx[\"is_manager\"] = True\n530\t            messages.success(request, \"You are now the owner of this project!\")\n531\t\n532\t        elif \"reject_transfer\" in request.POST:\n533\t            tr = project.transfer_request()\n534\t            if not tr or tr.user != request.user:\n535\t                return HttpResponseForbidden()\n536\t\n537\t            tr.transfer_request_date = None\n538\t            tr.save()\n539\t\n540\t    mq = project.member_set.select_related(\"user\").order_by(\"user__email\")\n541\t    ctx[\"memberships\"] = list(mq)\n542\t    return render(request, \"accounts/project.html\", ctx)\n543\t\n544\t\n545\t@login_required\n546\tdef notifications(request: AuthenticatedHttpRequest) -> HttpResponse:\n547\t    profile = request.profile\n548\t\n549\t    ctx = {\n550\t        \"status\": \"default\",\n551\t        \"page\": \"profile\",\n552\t        \"profile\": profile,\n553\t        \"timezones\": all_timezones,\n554\t    }\n555\t\n556\t    if request.method == \"POST\":\n557\t        form = forms.ReportSettingsForm(request.POST)\n558\t        if form.is_valid():\n559\t            profile.reports = form.cleaned_data[\"reports\"]\n560\t            profile.next_report_date = profile.choose_next_report_date()\n561\t\n562\t            if profile.nag_period != form.cleaned_data[\"nag_period\"]:\n563\t                # Set the new nag period\n564\t                profile.nag_period = form.cleaned_data[\"nag_period\"]\n565\t                # and update next_nag_date:\n566\t                if profile.nag_period:\n567\t                    profile.update_next_nag_date()\n568\t                else:\n569\t                    profile.next_nag_date = None\n570\t\n571\t            profile.save()\n572\t            ctx[\"status\"] = \"info\"\n573\t\n574\t    return render(request, \"accounts/notifications.html\", ctx)\n575\t\n576\t\n577\t@login_required\n578\t@sensitive_post_parameters()\n579\t@require_sudo_mode\n580\tdef set_password(request: AuthenticatedHttpRequest) -> HttpResponse:\n581\t    if request.method == \"POST\":\n582\t        form = forms.SetPasswordForm(request.POST)\n583\t        if form.is_valid():\n584\t            password = form.cleaned_data[\"password\"]\n585\t            request.user.set_password(password)\n586\t            request.user.save()\n587\t\n588\t            request.profile.token = \"\"\n589\t            request.profile.save()\n590\t\n591\t            # update the session with the new password hash so that\n592\t            # the user doesn't  get logged out\n593\t            update_session_auth_hash(request, request.user)\n594\t\n595\t            request.session[\"changed_password\"] = True\n596\t            return redirect(\"hc-profile\")\n597\t\n598\t    return render(request, \"accounts/set_password.html\", {})\n599\t\n600\t\n601\t@login_required\n602\t@require_sudo_mode\n603\tdef change_email(request: AuthenticatedHttpRequest) -> HttpResponse:\n604\t    if \"sent\" in request.session:\n605\t        ctx = {\"email\": request.session.pop(\"sent\")}\n606\t        return render(request, \"accounts/change_email_instructions.html\", ctx)\n607\t\n608\t    if request.method == \"POST\":\n609\t        form = forms.ChangeEmailForm(request.POST)\n610\t        if form.is_valid():\n611\t            # The user has entered a valid-looking new email address.\n612\t            # Send a special login link to the new address. When the user\n613\t            # clicks the special login link, hc.accounts.views.change_email_verify\n614\t            # unpacks the payload, and passes it to hc.accounts.views.check_token,\n615\t            # which finally updates user's email address.\n616\t            email = form.cleaned_data[\"email\"]\n617\t            request.profile.send_change_email_link(email)\n618\t            request.session[\"sent\"] = email\n619\t\n620\t            response = redirect(reverse(\"hc-change-email\"))\n621\t            # check_token looks for this cookie to decide if\n622\t            # it needs to do the extra POST step.\n623\t            _set_autologin_cookie(response)\n624\t            return response\n625\t    else:\n626\t        form = forms.ChangeEmailForm()\n627\t\n628\t    return render(request, \"accounts/change_email.html\", {\"form\": form})\n629\t\n630\t\n631\tdef change_email_verify(request: HttpRequest, signed_payload: str) -> HttpResponse:\n632\t    try:\n633\t        payload = TimestampSigner().unsign_object(signed_payload, max_age=900)\n634\t    except BadSignature:\n635\t        return render(request, \"bad_link.html\")\n636\t\n637\t    return check_token(request, payload[\"u\"], payload[\"t\"], payload[\"e\"])\n638\t\n639\t\n640\t@csrf_exempt\n641\tdef unsubscribe_reports(request: HttpRequest, signed_username: str) -> HttpResponse:\n642\t    # Some email servers open links in emails to check for malicious content.\n643\t    # To work around this, for GET requests we serve a confirmation form.\n644\t    # If the signature is more than 5 minutes old, we also include JS code to\n645\t    # auto-submit the form.\n646\t\n647\t    signer = TimestampSigner(salt=\"reports\")\n648\t    # First, check the signature without looking at the timestamp:\n649\t    try:\n650\t        username = signer.unsign(signed_username)\n651\t    except BadSignature:\n652\t        return render(request, \"bad_link.html\")\n653\t\n654\t    try:\n655\t        user = User.objects.get(username=username)\n656\t    except User.DoesNotExist:\n657\t        # This is likely an old unsubscribe link, and the user account has already\n658\t        # been deleted. Show the \"Unsubscribed!\" page nevertheless.\n659\t        return render(request, \"accounts/unsubscribed.html\")\n660\t\n661\t    if request.method != \"POST\":\n662\t        # Unsign again, now with max_age set,\n663\t        # to see if the timestamp is older than 5 minutes\n664\t        try:\n665\t            autosubmit = False\n666\t            username = signer.unsign(signed_username, max_age=300)\n667\t        except SignatureExpired:\n668\t            autosubmit = True\n669\t\n670\t        ctx = {\"autosubmit\": autosubmit}\n671\t        return render(request, \"accounts/unsubscribe_submit.html\", ctx)\n672\t\n673\t    profile = Profile.objects.for_user(user)\n674\t    profile.reports = \"off\"\n675\t    profile.next_report_date = None\n676\t    profile.nag_period = td()\n677\t    profile.next_nag_date = None\n678\t    profile.save()\n679\t\n680\t    return render(request, \"accounts/unsubscribed.html\")\n681\t\n682\t\n683\t@login_required\n684\t@require_sudo_mode\n685\tdef close(request: AuthenticatedHttpRequest) -> HttpResponse:\n686\t    user = request.user\n687\t\n688\t    if request.method == \"POST\":\n689\t        if request.POST.get(\"confirmation\") == request.user.email:\n690\t            # Cancel their subscription:\n691\t            if sub := Subscription.objects.filter(user=user).first():\n692\t                sub.cancel()\n693\t\n694\t            # Deleting user also deletes its profile, checks, channels etc.\n695\t            user.delete()\n696\t\n697\t            request.session.flush()\n698\t            path = reverse(\"hc-login\", query={\"account-closed\": 1})\n699\t            return redirect(path)\n700\t\n701\t    ctx = {}\n702\t    if \"confirmation\" in request.POST:\n703\t        ctx[\"wrong_confirmation\"] = True\n704\t\n705\t    return render(request, \"accounts/close_account.html\", ctx)\n706\t\n707\t\n708\t@require_POST\n709\t@login_required\n710\tdef remove_project(request: AuthenticatedHttpRequest, code: str) -> HttpResponse:\n711\t    project = get_object_or_404(Project, code=code, owner=request.user)\n712\t    for check in project.check_set.all():\n713\t        check.rename_and_delete()\n714\t    project.delete()\n715\t    return redirect(\"hc-index\")\n716\t\n717\t\n718\t@login_required\n719\t@require_sudo_mode\n720\tdef add_webauthn(request: AuthenticatedHttpRequest) -> HttpResponse:\n721\t    if not settings.RP_ID:\n722\t        return HttpResponse(status=404)\n723\t\n724\t    q = request.user.credentials.values_list(\"data\", flat=True)\n725\t    # CreateHelper wants list[bytes] so normalize to that\n726\t    credentials = [bytes(item) for item in q]\n727\t    helper = CreateHelper(settings.RP_ID, credentials)\n728\t\n729\t    if request.method == \"POST\":\n730\t        form = forms.AddWebAuthnForm(request.POST)\n731\t        if not form.is_valid():\n732\t            return HttpResponseBadRequest()\n733\t\n734\t        state = request.session[\"state\"]\n735\t        try:\n736\t            credential_bytes = helper.verify(state, form.cleaned_data[\"response\"])\n737\t        except ValueError:\n738\t            logger.exception(\"CreateHelper.verify failed, form: %s\", form.cleaned_data)\n739\t            return HttpResponseBadRequest()\n740\t\n741\t        c = Credential(user=request.user)\n742\t        c.name = form.cleaned_data[\"name\"]\n743\t        c.data = credential_bytes\n744\t        c.save()\n745\t\n746\t        request.session.pop(\"state\")\n747\t        request.session[\"added_credential_name\"] = c.name\n748\t        return redirect(\"hc-profile\")\n749\t\n750\t    options, request.session[\"state\"] = helper.prepare(request.user.email)\n751\t    return render(request, \"accounts/add_credential.html\", {\"options\": options})\n752\t\n753\t\n754\t@login_required\n755\t@require_sudo_mode\n756\tdef add_totp(request: AuthenticatedHttpRequest) -> HttpResponse:\n757\t    if request.profile.totp:\n758\t        # TOTP is already configured, refuse to continue\n759\t        return HttpResponseBadRequest()\n760\t\n761\t    if \"totp_secret\" not in request.session:\n762\t        request.session[\"totp_secret\"] = pyotp.random_base32()\n763\t\n764\t    totp = pyotp.totp.TOTP(request.session[\"totp_secret\"])\n765\t\n766\t    if request.method == \"POST\":\n767\t        form = forms.TotpForm(totp, request.POST)\n768\t        if form.is_valid():\n769\t            request.profile.totp = request.session[\"totp_secret\"]\n770\t            request.profile.totp_created = now()\n771\t            request.profile.save()\n772\t\n773\t            request.session[\"enabled_totp\"] = True\n774\t            request.session.pop(\"totp_secret\")\n775\t            return redirect(\"hc-profile\")\n776\t    else:\n777\t        form = forms.TotpForm(totp)\n778\t\n779\t    uri = totp.provisioning_uri(name=request.user.email, issuer_name=settings.SITE_NAME)\n780\t    qr_data_uri = segno.make(uri).png_data_uri(scale=8)\n781\t    ctx = {\n782\t        \"form\": form,\n783\t        \"qr_data_uri\": qr_data_uri,\n784\t        \"secret\": request.session[\"totp_secret\"],\n785\t    }\n786\t    return render(request, \"accounts/add_totp.html\", ctx)\n787\t\n788\t\n789\t@login_required\n790\t@require_sudo_mode\n791\tdef remove_totp(request: AuthenticatedHttpRequest) -> HttpResponse:\n792\t    if request.method == \"POST\" and \"disable_totp\" in request.POST:\n793\t        request.profile.totp = None\n794\t        request.profile.totp_created = None\n795\t        request.profile.save()\n796\t        request.session[\"disabled_totp\"] = True\n797\t        return redirect(\"hc-profile\")\n798\t\n799\t    ctx = {\"is_last\": not request.user.credentials.exists()}\n800\t    return render(request, \"accounts/remove_totp.html\", ctx)\n801\t\n802\t\n803\t@login_required\n804\t@require_sudo_mode\n805\tdef remove_credential(request: AuthenticatedHttpRequest, code: str) -> HttpResponse:\n806\t    if not settings.RP_ID:\n807\t        return HttpResponse(status=404)\n808\t\n809\t    try:\n810\t        credential = Credential.objects.get(user=request.user, code=code)\n811\t    except Credential.DoesNotExist:\n812\t        return HttpResponseBadRequest()\n813\t\n814\t    if request.method == \"POST\" and \"remove_credential\" in request.POST:\n815\t        request.session[\"removed_credential_name\"] = credential.name\n816\t        credential.delete()\n817\t        return redirect(\"hc-profile\")\n818\t\n819\t    if request.profile.totp:\n820\t        is_last = False\n821\t    else:\n822\t        is_last = request.user.credentials.count() == 1\n823\t\n824\t    ctx = {\"credential\": credential, \"is_last\": is_last}\n825\t    return render(request, \"accounts/remove_credential.html\", ctx)\n826\t\n827\t\n828\tdef login_webauthn(request: HttpRequest) -> HttpResponse:\n829\t    # We require RP_ID. Fail predicably if it is not set:\n830\t    if not settings.RP_ID:\n831\t        return HttpResponse(status=404)\n832\t\n833\t    # Expect an unauthenticated user\n834\t    if request.user.is_authenticated:\n835\t        return HttpResponseBadRequest()\n836\t\n837\t    if \"2fa_user\" not in request.session:\n838\t        return HttpResponseBadRequest()\n839\t\n840\t    user_id, email, timestamp = request.session[\"2fa_user\"]\n841\t    if timestamp + 300 < time.time():\n842\t        return redirect(\"hc-login\")\n843\t\n844\t    try:\n845\t        user = User.objects.get(id=user_id, email=email)\n846\t    except User.DoesNotExist:\n847\t        return HttpResponseBadRequest()\n848\t\n849\t    q = user.credentials.values_list(\"data\", flat=True)\n850\t    # GetHelper wants list[bytes] so normalize to that\n851\t    credentials = [bytes(item) for item in q]\n852\t    helper = GetHelper(settings.RP_ID, credentials)\n853\t\n854\t    if request.method == \"POST\":\n855\t        form = forms.WebAuthnForm(request.POST)\n856\t        if not form.is_valid():\n857\t            return HttpResponseBadRequest()\n858\t\n859\t        if not helper.verify(request.session[\"state\"], form.cleaned_data[\"response\"]):\n860\t            return HttpResponseBadRequest()\n861\t\n862\t        request.session.pop(\"state\")\n863\t        request.session.pop(\"2fa_user\")\n864\t        auth_login(request, user, \"hc.accounts.backends.EmailBackend\")\n865\t        return _redirect_after_login(request)\n866\t\n867\t    options, request.session[\"state\"] = helper.prepare()\n868\t\n869\t    totp_url = None\n870\t    if user.profile.totp:\n871\t        query = {}\n872\t        if _allow_redirect(request.GET.get(\"next\")):\n873\t            query[\"next\"] = request.GET[\"next\"]\n874\t        totp_url = reverse(\"hc-login-totp\", query=query)\n875\t\n876\t    ctx = {\n877\t        \"options\": options,\n878\t        \"totp_url\": totp_url,\n879\t    }\n880\t    return render(request, \"accounts/login_webauthn.html\", ctx)\n881\t\n882\t\n883\tdef login_totp(request: HttpRequest) -> HttpResponse:\n884\t    # Expect an unauthenticated user\n885\t    if request.user.is_authenticated:\n886\t        return HttpResponseBadRequest()\n887\t\n888\t    if \"2fa_user\" not in request.session:\n889\t        return HttpResponseBadRequest()\n890\t\n891\t    user_id, email, timestamp = request.session[\"2fa_user\"]\n892\t    if timestamp + 300 < time.time():\n893\t        return redirect(\"hc-login\")\n894\t\n895\t    try:\n896\t        user = User.objects.get(id=user_id, email=email)\n897\t    except User.DoesNotExist:\n898\t        return HttpResponseBadRequest()\n899\t\n900\t    if not user.profile.totp:\n901\t        return HttpResponseBadRequest()\n902\t\n903\t    totp = pyotp.totp.TOTP(user.profile.totp)\n904\t    if request.method == \"POST\":\n905\t        # To guard against brute-forcing TOTP codes, we allow\n906\t        # 96 attempts per user per 24h.\n907\t        if not TokenBucket.authorize_totp_attempt(user):\n908\t            return render(request, \"try_later.html\")\n909\t\n910\t        form = forms.TotpForm(totp, request.POST)\n911\t        if form.is_valid():\n912\t            # We blacklist an used TOTP code for 90 seconds,\n913\t            # so an attacker cannot reuse a stolen code.\n914\t            if not TokenBucket.authorize_totp_code(user, form.cleaned_data[\"code\"]):\n915\t                return render(request, \"try_later.html\")\n916\t\n917\t            request.session.pop(\"2fa_user\")\n918\t            auth_login(request, user, \"hc.accounts.backends.EmailBackend\")\n919\t            return _redirect_after_login(request)\n920\t    else:\n921\t        form = forms.TotpForm(totp)\n922\t\n923\t    return render(request, \"accounts/login_totp.html\", {\"form\": form})\n924\t\n925\t\n926\t@login_required\n927\tdef appearance(request: AuthenticatedHttpRequest) -> HttpResponse:\n928\t    profile = request.profile\n929\t\n930\t    ctx = {\n931\t        \"page\": \"appearance\",\n932\t        \"profile\": profile,\n933\t        \"status\": \"default\",\n934\t    }\n935\t\n936\t    if request.method == \"POST\":\n937\t        theme = request.POST.get(\"theme\", \"\")\n938\t        if theme in (\"\", \"dark\", \"system\"):\n939\t            profile.theme = theme\n940\t            profile.save()\n941\t            ctx[\"status\"] = \"info\"\n942\t\n943\t    return render(request, \"accounts/appearance.html\", ctx)\n944\t"
