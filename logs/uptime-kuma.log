        "content": "1\t<template>\n2\t    <div class=\"form-container\" data-cy=\"setup-form\">\n3\t        <div class=\"form\">\n4\t            <form @submit.prevent=\"submit\">\n5\t                <div>\n6\t                    <object width=\"64\" height=\"64\" data=\"/icon.svg\" />\n7\t                    <div style=\"font-size: 28px; font-weight: bold; margin-top: 5px\">Uptime Kuma</div>\n8\t                </div>\n9\t\n10\t                <p class=\"mt-3\">\n11\t                    {{ $t(\"Create your admin account\") }}\n12\t                </p>\n13\t\n14\t                <div class=\"form-floating\">\n15\t                    <select id=\"language\" v-model=\"$root.language\" class=\"form-select\">\n16\t                        <option v-for=\"(lang, i) in $i18n.availableLocales\" :key=\"`Lang${i}`\" :value=\"lang\">\n17\t                            {{ $i18n.messages[lang].languageName }}\n18\t                        </option>\n19\t                    </select>\n20\t                    <label for=\"language\" class=\"form-label\">{{ $t(\"Language\") }}</label>\n21\t                </div>\n22\t\n23\t                <div class=\"form-floating mt-3\">\n24\t                    <input\n25\t                        id=\"floatingInput\"\n26\t                        v-model=\"username\"\n27\t                        type=\"text\"\n28\t                        class=\"form-control\"\n29\t                        :placeholder=\"$t('Username')\"\n30\t                        required\n31\t                        data-cy=\"username-input\"\n32\t                    />\n33\t                    <label for=\"floatingInput\">{{ $t(\"Username\") }}</label>\n34\t                </div>\n35\t\n36\t                <div class=\"form-floating mt-3\">\n37\t                    <input\n38\t                        id=\"floatingPassword\"\n39\t                        v-model=\"password\"\n40\t                        type=\"password\"\n41\t                        class=\"form-control\"\n42\t                        :placeholder=\"$t('Password')\"\n43\t                        required\n44\t                        data-cy=\"password-input\"\n45\t                    />\n46\t                    <label for=\"floatingPassword\">{{ $t(\"Password\") }}</label>\n47\t                </div>\n48\t\n49\t                <div class=\"form-floating mt-3\">\n50\t                    <input\n51\t                        id=\"repeat\"\n52\t                        v-model=\"repeatPassword\"\n53\t                        type=\"password\"\n54\t                        class=\"form-control\"\n55\t                        :placeholder=\"$t('Repeat Password')\"\n56\t                        required\n57\t                        data-cy=\"password-repeat-input\"\n58\t                    />\n59\t                    <label for=\"repeat\">{{ $t(\"Repeat Password\") }}</label>\n60\t                </div>\n61\t\n62\t                <button\n63\t                    class=\"w-100 btn btn-primary mt-3\"\n64\t                    type=\"submit\"\n65\t                    :disabled=\"processing\"\n66\t                    data-cy=\"submit-setup-form\"\n67\t                >\n68\t                    {{ $t(\"Create\") }}\n69\t                </button>\n70\t            </form>\n71\t        </div>\n72\t    </div>\n73\t</template>\n74\t\n75\t<script>\n76\texport default {\n77\t    data() {\n78\t        return {\n79\t            processing: false,\n80\t            username: \"\",\n81\t            password: \"\",\n82\t            repeatPassword: \"\",\n83\t        };\n84\t    },\n85\t    watch: {},\n86\t    mounted() {\n87\t        // TODO: Check if it is a database setup\n88\t\n89\t        this.$root.getSocket().emit(\"needSetup\", (needSetup) => {\n90\t            if (!needSetup) {\n91\t                this.$router.push(\"/\");\n92\t            }\n93\t        });\n94\t    },\n95\t    methods: {\n96\t        /**\n97\t         * Submit form data for processing\n98\t         * @returns {void}\n99\t         */\n100\t        submit() {\n101\t            this.processing = true;\n102\t\n103\t            if (this.password !== this.repeatPassword) {\n104\t                this.$root.toastError(\"PasswordsDoNotMatch\");\n105\t                this.processing = false;\n106\t                return;\n107\t            }\n108\t\n109\t            this.$root.getSocket().emit(\"setup\", this.username, this.password, (res) => {\n110\t                this.processing = false;\n111\t                this.$root.toastRes(res);\n112\t\n113\t                if (res.ok) {\n114\t                    this.processing = true;\n115\t\n116\t                    this.$root.login(this.username, this.password, \"\", () => {\n117\t                        this.processing = false;\n118\t                        this.$router.push(\"/\");\n119\t                    });\n120\t                }\n121\t            });\n122\t        },\n123\t    },\n124\t};\n125\t</script>\n126\t\n127\t<style lang=\"scss\" scoped>\n128\t.form-container {\n129\t    display: flex;\n130\t    align-items: center;\n131\t    padding-top: 40px;\n132\t    padding-bottom: 40px;\n133\t}\n134\t\n135\t.form-floating {\n136\t    > .form-select {\n137\t        padding-left: 1.3rem;\n138\t        padding-top: 1.525rem;\n139\t        line-height: 1.35;\n140\t\n141\t        ~ label {\n142\t            padding-left: 1.3rem;\n143\t        }\n144\t    }\n145\t\n146\t    > label {\n147\t        padding-left: 1.3rem;\n148\t    }\n149\t\n150\t    > .form-control {\n151\t        padding-left: 1.3rem;\n152\t    }\n153\t}\n154\t\n155\t.form {\n156\t    width: 100%;\n157\t    max-width: 330px;\n158\t    padding: 15px;\n159\t    margin: auto;\n160\t    text-align: center;\n161\t}\n162\t</style>\n163\t"
