rList = data;\n202\t            });\n203\t\n204\t            socket.on(\"heartbeat\", (data) => {\n205\t                if (!(data.monitorID in this.heartbeatList)) {\n206\t                    this.heartbeatList[data.monitorID] = [];\n207\t                }\n208\t\n209\t                this.heartbeatList[data.monitorID].push(data);\n210\t\n211\t                if (this.heartbeatList[data.monitorID].length >= 150) {\n212\t                    this.heartbeatList[data.monitorID].shift();\n213\t                }\n214\t\n215\t                // Add to important list if it is important\n216\t                // Also toast\n217\t                if (data.important) {\n218\t                    if (this.monitorList[data.monitorID] !== undefined) {\n219\t                        if (data.status === 0) {\n220\t                            toast.error(`[${this.monitorList[data.monitorID].name}] [DOWN] ${data.msg}`, {\n221\t                                timeout: getToastErrorTimeout(),\n222\t                            });\n223\t                        } else if (data.status === 1) {\n224\t                            toast.success(`[${this.monitorList[data.monitorID].name}] [Up] ${data.msg}`, {\n225\t                                timeout: getToastSuccessTimeout(),\n226\t                            });\n227\t                        } else {\n228\t                            toast(`[${this.monitorList[data.monitorID].name}] ${data.msg}`);\n229\t                        }\n230\t                    }\n231\t\n232\t                    this.emitter.emit(\"newImportantHeartbeat\", data);\n233\t                }\n234\t            });\n235\t\n236\t            socket.on(\"heartbeatList\", (monitorID, data, overwrite = false) => {\n237\t                if (!(monitorID in this.heartbeatList) || overwrite) {\n238\t                    this.heartbeatList[monitorID] = data;\n239\t                } else {\n240\t                    this.heartbeatList[monitorID] = data.concat(this.heartbeatList[monit