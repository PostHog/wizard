    "content": [
      {
        "tool_use_id": "toolu_01LKhXm4YgEWXH6ihMf4Y6VG",
        "type": "tool_result",
        "content": [
          {
            "type": "text",
            "text": "name: insight-create\ntitle: Create insight\ndescription: Create a new saved insight from a name and query definition. Test queries with query-trends / query-funnel / query-retention / query-paths / query-stickiness / query-lifecycle first to confirm the shape, then save. Returns insight metadata only — after creating, call the insight-query tool with the returned `short_id` if you want to see the computed results.\nannotations:\n  destructiveHint: false\n  idempotentHint: false\n  openWorldHint: true\n  readOnlyHint: false\ninputSchema: \"{\\\"$schema\\\":\\\"https://json-schema.org/draft/2020-12/schema\\\",\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"name\\\":{\\\"anyOf\\\":[{\\\"type\\\":\\\"string\\\",\\\"maxLength\\\":400},{\\\"type\\\":\\\"null\\\"}]},\\\"dashboards\\\":{\\\"description\\\":\\\"Dashboard IDs this insight should belong to. This is a full replacement — always include all existing dashboard IDs when adding a new one.\\\",\\\"type\\\":\\\"array\\\",\\\"items\\\":{\\\"type\\\":\\\"number\\\"}},\\\"description\\\":{\\\"anyOf\\\":[{\\\"type\\\":\\\"string\\\",\\\"maxLength\\\":400},{\\\"type\\\":\\\"null\\\"}]},\\\"tags\\\":{\\\"type\\\":\\\"array\\\",\\\"items\\\":{}},\\\"favorited\\\":{\\\"type\\\":\\\"boolean\\\"},\\\"query\\\":{\\\"anyOf\\\":[{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"kind\\\":{\\\"default\\\":\\\"InsightVizNode\\\",\\\"type\\\":\\\"string\\\",\\\"const\\\":\\\"InsightVizNode\\\"},\\\"source\\\":{\\\"type\\\":\\\"object\\\",\\\"propertyNames\\\":{\\\"type\\\":\\\"string\\\"},\\\"additionalProperties\\\":{},\\\"description\\\":\\\"Product analtycs query objects like TrendsQuery, FunnelsQuery, RetentionQuery, PathsQuery, StickinessQuery, LifecycleQuery\\\"}},\\\"required\\\":[\\\"kind\\\",\\\"source\\\"],\\\"additionalProperties\\\":false},{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"chartSettings\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"goalLines\\\":{\\\"type\\\":\\\"array\\\",\\\"items\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"label\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Label rendered next to the goal line.\\\"},\\\"value\\\":{\\\"type\\\":\\\"number\\\",\\\"description\\\":\\\"Y-axis value at which the goal line is drawn.\\\"}},\\\"required\\\":[\\\"label\\\",\\\"value\\\"],\\\"additionalProperties\\\":false},\\\"description\\\":\\\"Horizontal goal lines drawn across the chart.\\\"},\\\"leftYAxisSettings\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"label\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Label rendered beside this Y axis.\\\"},\\\"scale\\\":{\\\"type\\\":\\\"string\\\",\\\"enum\\\":[\\\"linear\\\",\\\"logarithmic\\\"],\\\"description\\\":\\\"Scale used for this Y axis.\\\"},\\\"showGridLines\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Show grid lines for this Y axis.\\\"},\\\"showTicks\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Show tick labels on this Y axis.\\\"},\\\"startAtZero\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Whether this Y axis should start at zero.\\\"}},\\\"additionalProperties\\\":false,\\\"description\\\":\\\"Settings for the left Y axis.\\\"},\\\"rightYAxisSettings\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"label\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Label rendered beside this Y axis.\\\"},\\\"scale\\\":{\\\"type\\\":\\\"string\\\",\\\"enum\\\":[\\\"linear\\\",\\\"logarithmic\\\"],\\\"description\\\":\\\"Scale used for this Y axis.\\\"},\\\"showGridLines\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Show grid lines for this Y axis.\\\"},\\\"showTicks\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Show tick labels on this Y axis.\\\"},\\\"startAtZero\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Whether this Y axis should start at zero.\\\"}},\\\"additionalProperties\\\":false,\\\"description\\\":\\\"Settings for the right Y axis. 