ll, 4);\n4130\t            }\n4131\t\n4132\t            if (this.monitor.hostname) {\n4133\t                this.monitor.hostname = this.monitor.hostname.trim();\n4134\t            }\n4135\t\n4136\t            if (this.monitor.url) {\n4137\t                this.monitor.url = this.monitor.url.trim();\n4138\t            }\n4139\t\n4140\t            if (this.monitor.databaseConnectionString) {\n4141\t                this.monitor.databaseConnectionString = this.monitor.databaseConnectionString.trim();\n4142\t            }\n4143\t\n4144\t            if (this.monitor.type === \"oracledb\") {\n4145\t                if (this.monitor.basic_auth_user) {\n4146\t                    this.monitor.basic_auth_user = this.monitor.basic_auth_user.trim();\n4147\t                }\n4148\t\n4149\t                if (this.monitor.basic_auth_pass) {\n4150\t                    this.monitor.basic_auth_pass = this.monitor.basic_auth_pass.trim();\n4151\t                }\n4152\t            }\n4153\t\n4154\t            let createdNewParent = false;\n4155\t\n4156\t            if (this.draftGroupName && this.monitor.parent === -1) {\n4157\t                // Create Monitor with name of draft group\n4158\t                const res = await new Promise((resolve) => {\n4159\t                    this.$root.add(\n4160\t                        {\n4161\t                            ...monitorDefaults,\n4162\t                            type: \"group\",\n4163\t                            name: this.draftGroupName,\n4164\t                            interval: this.monitor.interval,\n4165\t                            active: false,\n4166\t                        },\n4167\t                        resolve\n4168\t                    );\n4169\t                });"
