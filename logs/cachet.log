          {
            "type": "text",
            "text": "name: insight-create\ntitle: Create insight\ndescription: Create a new saved insight from a name and query definition. Test queries with query-trends / query-funnel / query-retention / query-paths / query-stickiness / query-lifecycle first to confirm the shape, then save. Returns insight metadata only — after creating, call the insight-query tool with the returned `short_id` if you want to see the computed results.\nannotations:\n  destructiveHint: false\n  idempotentHint: false\n  openWorldHint: true\n  readOnlyHint: false\ninputSchema: \"{\\\"$schema\\\":\\\"https://json-schema.org/draft/2020-12/schema\\\",\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"name\\\":{\\\"anyOf\\\":[{\\\"type\\\":\\\"string\\\",\\\"maxLength\\\":400},{\\\"type\\\":\\\"null\\\"}]},\\\"dashboards\\\":{\\\"description\\\":\\\"Dashboard IDs this insight should belong to. This is a full replacement — always include all existing dashboard IDs when adding a new one.\\\",\\\"type\\\":\\\"array\\\",\\\"items\\\":{\\\"type\\\":\\\"number\\\"}},\\\"description\\\":{\\\"anyOf\\\":[{\\\"type\\\":\\\"string\\\",\\\"maxLength\\\":400},{\\\"type\\\":\\\"null\\\"}]},\\\"tags\\\":{\\\"type\\\":\\\"array\\\",\\\"items\\\":{}},\\\"favorited\\\":{\\\"type\\\":\\\"boolean\\\"},\\\"query\\\":{\\\"anyOf\\\":[{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"kind\\\":{\\\"default\\\":\\\"InsightVizNode\\\",\\\"type\\\":\\\"string\\\",\\\"const\\\":\\\"InsightVizNode\\\"},\\\"source\\\":{\\\"type\\\":\\\"object\\\",\\\"propertyNames\\\":{\\\"type\\\":\\\"string\\\"},\\\"additionalProperties\\\":{},\\\"description\\\":\\\"Product analtycs query objects like TrendsQuery, FunnelsQuery, RetentionQuery, PathsQuery, StickinessQuery, LifecycleQuery\\\"}},\\\"required\\\":[\\\"kind\\\",\\\"source\\\"],\\\"additionalProperties\\\":false},{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"chartSettings\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"goalLines\\\":{\\\"type\\\":\\\"array\\\",\\\"items\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"label\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Label rendered next to the goal line.\\\"},\\\"value\\\":{\\\"type\\\":\\\"number\\\",\\\"description\\\":\\\"Y-axis value at which the goal line is drawn.\\\"}},\\\"required\\\":[\\\"label\\\",\\\"value\\\"],\\\"additionalProperties\\\":false},\\\"description\\\":\\\"Horizontal goal lines drawn across the chart.\\\"},\\\"leftYAxisSettings\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"label\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Label rendered beside this Y axis.\\\"},\\\"scale\\\":{\\\"type\\\":\\\"string\\\",\\\"enum\\\":[\\\"linear\\\",\\\"logarithmic\\\"],\\\"description\\\":\\\"Scale used for this Y axis.\\\"},\\\"showGridLines\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Show grid lines for this Y axis.\\\"},\\\"showTicks\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Show tick labels on this Y axis.\\\"},\\\"startAtZero\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Whether this Y axis should start at zero.\\\"}},\\\"additionalProperties\\\":false,\\\"description\\\":\\\"Settings for the left Y axis.\\\"},\\\"rightYAxisSettings\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"label\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Label rendered beside this Y axis.\\\"},\\\"scale\\\":{\\\"type\\\":\\\"string\\\",\\\"enum\\\":[\\\"linear\\\",\\\"logarithmic\\\"],\\\"description\\\":\\\"Scale used for this Y axis.\\\"},\\\"showGridLines\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Show grid lines for this Y axis.\\\"},\\\"showTicks\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Show tick labels on this Y axis.\\\"},\\\"startAtZero\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Whether this Y axis should start at zero.\\\"}},\\\"additionalProperties\\\":false,\\\"description\\\":\\\"Settings for the right Y axis. Only applies when a Y series uses `settings.display.yAxisPosition: \\\\\\\"right\\\\\\\"`.\\\"},\\\"seriesBreakdownColumn\\\":{\\\"anyOf\\\":[{\\\"type\\\":\\\"string\\\"},{\\\"type\\\":\\\"null\\\"}],\\\"description\\\":\\\"Column that splits a single Y series into multiple colored series — e.g. breaking down a line chart by `country`. Set to `null` or omit to disable.\\\"},\\\"showLegend\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Show the chart legend.\\\"},\\\"showNullsAsZero\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Replace null aggregation results with zero.\\\"},\\\"showValuesOnSeries\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Render each data point's value as a label directly on the series.\\\"},\\\"stackBars100\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Stack bars to 100% of the total. Only meaningful with `ActionsStackedBar`.\\\"},\\\"xAxis\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"column\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Name of a column returned by the SQL query to map onto this axis.\\\"},\\\"settings\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"display\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"color\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Custom color for this series as a hex string (e.g. `#1d4aff`).\\\"},\\\"displayType\\\":{\\\"type\\\":\\\"string\\\",\\\"enum\\\":[\\\"auto\\\",\\\"line\\\",\\\"bar\\\",\\\"area\\\"],\\\"description\\\":\\\"Override how this individual series is rendered, independent of the chart-level `display` type. Use this to mix series types — e.g. plot one series as `bar` and overlay another as `line`. `auto` follows the chart-level display type.\\\"},\\\"label\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Custom label for this series, shown in the legend and tooltips instead of the column name.\\\"},\\\"trendLine\\\":{\\\"type\\\":\\\"boolean\\\",\\\"description\\\":\\\"Draw a linear trend line for this series. Only meaningful for line, bar, and area charts.\\\"},\\\"yAxisPosition\\\":{\\\"type\\\":\\\"string\\\",\\\"enum\\\":[\\\"left\\\",\\\"right\\\"],\\\"description\\\":\\\"Which Y axis this numeric series should use. Use `right` for a secondary Y axis.\\\"}},\\\"additionalProperties\\\":false,\\\"description\\\":\\\"Display settings for a plotted Y series.\\\"},\\\"formatting\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"decimalPlaces\\\":{\\\"type\\\":\\\"number\\\",\\\"description\\\":\\\"Number of decimal places to display.\\\"},\\\"prefix\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Text prepended to each value (e.g. `$`).\\\"},\\\"style\\\":{\\\"type\\\":\\\"string\\\",\\\"enum\\\":[\\\"none\\\",\\\"number\\\",\\\"short\\\",\\\"percent\\\"],\\\"description\\\":\\\"Number formatting style.\\\\n- `none` — no formatting.\\\\n- `number` — thousands separators (e.g. `1,234`).\\\\n- `short` — abbreviated large numbers (e.g. `1.2k`, `3.4M`).\\\\n- `percent` — render the value as a percentage.\\\"},\\\"suffix\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Text appended to each value (e.g. `%` or ` ms`).\\\"}},\\\"additionalProperties\\\":false,\\\"description\\\":\\\"Number-formatting settings for the values on this axis or series.\\\"}},\\\"additionalProperties\\\":false,\\\"description\\\":\\\"Optional series settings. Only applies to Y-axis series.\\\"}},\\\"required\\\":[\\\"column\\\"],\\\"additionalProperties\\\":false,\\\"description\\\":\\\"Column used as the X axis. Typically a time bucket or categorical column.\\\"},\\\"xAxisLabel\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Label rendered under the X axis.\\\"},\\\"yAxis\\\":{\\\"type\\\":\\\"array\\\",\\\"items\\\":{\\\"type\\\":\\\"object\\\",\\\"properties\\\":{\\\"column\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"Name of a column returned by the SQL query to map onto this axis.\\\"},\\\"settings\\\":{\\\"type\\\":