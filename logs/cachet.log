          "old_string": "namespace App\\Providers;\n\nuse Illuminate\\Cache\\RateLimiting\\Limit;\nuse Illuminate\\Http\\Request;\nuse Illuminate\\Support\\Facades\\RateLimiter;\nuse Illuminate\\Support\\ServiceProvider;\n\nclass AppServiceProvider extends ServiceProvider\n{\n    /**\n     * The path to your application's \"home\" route.\n     *\n     * Typically, users are redirected here after authentication.\n     *\n     * @var string\n     */\n    public const HOME = '/home';\n\n    /**\n     * Register any application services.\n     */\n    public function register(): void\n    {\n        //\n    }\n\n    /**\n     * Bootstrap any application services.\n     */\n    public function boot(): void\n    {\n        //\n\n        $this->bootRoute();\n    }\n\n    public function bootRoute(): void\n    {\n        RateLimiter::for('api', function (Request $request) {\n            return Limit::perMinute(60)->by($request->user()?->id ?: $request->ip());\n        });\n    }\n}",
          "new_string": "namespace App\\Providers;\n\nuse App\\Services\\PostHogService;\nuse Illuminate\\Auth\\Events\\Login;\nuse Illuminate\\Auth\\Events\\Logout;\nuse Illuminate\\Auth\\Events\\Registered;\nuse Illuminate\\Cache\\RateLimiting\\Limit;\nuse Illuminate\\Http\\Request;\nuse Illuminate\\Support\\Facades\\Event;\nuse Illuminate\\Support\\Facades\\RateLimiter;\nuse Illuminate\\Support\\ServiceProvider;\n\nclass AppServiceProvider extends ServiceProvider\n{\n    /**\n     * The path to your application's \"home\" route.\n     *\n     * Typically, users are redirected here after authentication.\n     *\n     * @var string\n     */\n    public const HOME = '/home';\n\n    /**\n     * Register any application services.\n     */\n    public function register(): void\n    {\n        //\n\n        $this->app->singleton(PostHogService::class, fn () => new PostHogService());\n    }\n\n    /**\n     * Bootstrap any application services.\n     */\n    public function boot(): void\n    {\n        //\n\n        $this->bootRoute();\n        $this->bootPostHog();\n    }\n\n    public function bootRoute(): void\n    {\n        RateLimiter::for('api', function (Request $request) {\n            return Limit::perMinute(60)->by($request->user()?->id ?: $request->ip());\n        });\n    }\n\n    protected function bootPostHog(): void\n    {\n        /** @var PostHogService $posthog */\n        $posthog = $this->app->make(PostHogService::class);\n\n        // Track user login\n        Event::listen(Login::class, function (Login $event) use ($posthog) {\n            $user = $event->user;\n            $posthog->identify($user->email, $user->getPostHogProperties());\n            $posthog->capture($user->email, 'user_logged_in', [\n                'login_method' => 'password',\n            ]);\n        });\n\n        // Track user logout\n        Event::listen(Logout::class, function (Logout $event) use ($posthog) {\n            if ($event->user) {\n                $posthog->capture($event->user->email, 'user_logged_out');\n            }\n        });\n\n        // Track user registration\n        Event::listen(Registered::class, function (Registered $event) use ($posthog) {\n            $user = $event->user;\n            $posthog->identify($user->email, $user->getPostHogProperties());\n            $posthog->capture($user->email, 'user_registered', [\n                'signup_method' => 'form',\n            ]);\n        });\n\n        // Track Cachet model events if models are available\n        $this->bootCachetModelEvents($posthog);\n    }\n\n    protected function bootCachetModelEvents(PostHogService $posthog): void\n    {\n        // Component events\n        if (class_exists(\\Cachet\\Models\\Component::class)) {\n            \\Cachet\\Models\\Component::created(function ($component) use ($posthog) {\n                $distinctId = \\Illuminate\\Support\\Facades\\Auth::user()?->email ?? 'system';\n                $posthog->capture($distinctId, 'component_created', [\n                    'component_name'   => $component->name,\n                    'component_status' => $component->status,\n                ]);\n            });\n\n            \\Cachet\\Models\\Component::updated(function ($component) use ($posthog) {\n                if (! $component->isDirty('status')) {\n                    return;\n                }\n                $distinctId = \\Illuminate\\Support\\Facades\\Auth::user()?->email ?? 'system';\n                $posthog->capture($distinctId, 'component_status_updated', [\n                    'component_name'    => $component->name,\n                    'old_status'        => $component->getOriginal('status'),\n                    'new_status'        => $component->status,\n                ]);\n            });\n        }\n\n        // Incident events\n        if (class_exists(\\Cachet\\Models\\Incident::class)) {\n            \\Cachet\\Models\\Incident::created(function ($incident) use ($posthog) {\n                $distinctId = \\Illuminate\\Support\\Facades\\Auth::user()?->email ?? 'system';\n                $posthog->capture($distinctId, 'incident_created', [\n                    'incident_name'   => $incident->name,\n                    'incident_status' => $incident->status,\n                ]);\n            });\n\n            \\Cachet\\Models\\Incident::updated(function ($incident) use ($posthog) {\n                if (! $incident->isDirty()) {\n                    return;\n                }\n                $distinctId = \\Illuminate\\Support\\Facades\\Auth::user()?->email ?? 'system';\n\n                // Check if this update resolves the incident\n                if ($incident->isDirty('status') && $incident->status === 4) {\n                    $posthog->capture($distinctId, 'incident_resolved', [\n                        'incident_name' => $incident->name,\n                    ]);\n                } else {\n                    $posthog->capture($distinctId, 'incident_updated', [\n                        'incident_name'   => $incident->name,\n                        'incident_status' => $incident->status,\n                    ]);\n                }\n            });\n        }\n\n        // Subscriber events\n        if (class_exists(\\Cachet\\Models\\Subscriber::class)) {\n            \\Cachet\\Models\\Subscriber::created(function ($subscriber) use ($posthog) {\n                $posthog->capture($subscriber->email ?? 'anonymous', 'subscriber_added', [\n                    'subscription_channel' => 'email',\n                ]);\n            });\n        }\n\n        // Scheduled maintenance events\n        if (class_exists(\\Cachet\\Models\\Schedule::class)) {\n            \\Cachet\\Models\\Schedule::created(function ($schedule) use ($posthog) {\n                $distinctId = \\Illuminate\\Support\\Facades\\Auth::user()?->email ?? 'system';\n                $posthog->capture($distinctId, 'scheduled_maintenance_created', [\n                    'schedule_name'         => $schedule->name,\n                    'scheduled_at'          => $schedule->scheduled_at?->toISOString(),\n                ]);\n            });\n        }\n    }\n}"
